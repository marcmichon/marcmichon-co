---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const products = [
	{
		name: 'MM Risk Score',
		category: 'Risk Management',
		description:
			'Évaluez un scénario de risque en combinant impact, probabilité et contrôles compensatoires.',
		status: 'released',
		statusLabel: 'Released',
		version: 'v1.0',
		href: '/labs/risk-matrix',
		image: '/Images/tools/risk-score.png',
	},
	{
		name: 'MM CVSS Calculator',
		category: 'Vulnerability Management',
		description:
			'Construisez et analysez des vecteurs CVSS v4.0 conformes au standard FIRST.',
		status: 'released',
		statusLabel: 'Released',
		version: 'v1.0',
		href: '/labs/cvss-calculator',
		image: '/Images/tools/cvss-calculator.png',
	},
	{
		name: 'MM Vulnerability Explorer',
		category: 'Vulnerability Intelligence',
		description:
			'Analysez une CVE et obtenez une priorisation opérationnelle basée sur plusieurs sources d’intelligence.',
		status: 'released',
		statusLabel: 'Released',
		version: 'v1.0',
		href: '/labs/vulnerability-explorer',
		image: '/Images/tools/vulnerability-explorer.png',
	},
	{
		name: 'MM IOC Analyzer',
		category: 'Threat Intelligence',
		description:
			'Détectez, normalisez, dédupliquez et préparez vos indicateurs de compromission pour l’investigation.',
		status: 'development',
		statusLabel: 'In Development',
		version: 'v0.1 Preview',
		icon: '⌁',
	},
	{
		name: 'MM Exposure Analyzer',
		category: 'Exposure Management',
		description:
			'Transformez les signaux d’exposition en priorités compréhensibles et actionnables.',
		status: 'planned',
		statusLabel: 'Planned',
		version: 'Concept',
		icon: '◎',
	},
	{
		name: 'MM Patch Planner',
		category: 'Remediation Operations',
		description:
			'Structurez les campagnes de correction selon le risque, les actifs et les contraintes opérationnelles.',
		status: 'planned',
		statusLabel: 'Planned',
		version: 'Concept',
		icon: '✓',
	},
	{
		name: 'MM Attack Path Explorer',
		category: 'Security Research',
		description:
			'Explorez les relations entre actifs, identités, privilèges et chemins d’attaque potentiels.',
		status: 'research',
		statusLabel: 'Research',
		version: 'Research',
		icon: '◇',
	},
];

const statusLegend = [
	{ status: 'released', label: 'Released' },
	{ status: 'development', label: 'In Development' },
	{ status: 'planned', label: 'Planned' },
	{ status: 'research', label: 'Research' },
];
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`MM Security Intelligence Suite | ${SITE_TITLE}`}
			description="Découvrez la suite MM Security Intelligence, ses outils disponibles et sa roadmap produit."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="hero-summary">
					<p class="eyebrow">Boîte à outils de cybersécurité</p>

					<div class="suite-brand-visual">
						<img
							src="/Images/tools/mm-intelligence-suite-blended.png"
							alt="Identité visuelle MM Intelligence Suite"
							loading="eager"
							decoding="async"
						/>
					</div>

					<p class="hero-lead">
						Une suite logicielle développée à partir de problématiques
						rencontrées quotidiennement sur le terrain.
					</p>

					<p class="hero-copy">
						Chaque produit répond à un besoin opérationnel concret : gestion du risque,
						gestion des vulnérabilités, Threat Intelligence, investigation et remédiation.
					</p>

					<div class="hero-actions">
						<a href="#roadmap" class="primary-action">Explorer la roadmap →</a>
					</div>

				</div>

				<aside class="hero-roadmap" aria-label="Aperçu de la roadmap produit">
					<div class="hero-roadmap-head">
						<p>MM Security Intelligence</p>
						<span>Product Roadmap</span>
					</div>

					<div class="roadmap-group">
						<p class="roadmap-label released-label">Released</p>
						<ul>
							<li>MM Risk Score</li>
							<li>MM CVSS Calculator</li>
							<li>MM Vulnerability Explorer</li>
						</ul>
					</div>

					<div class="roadmap-group">
						<p class="roadmap-label development-label">In Development</p>
						<ul>
							<li>MM IOC Analyzer</li>
						</ul>
					</div>

					<div class="roadmap-group">
						<p class="roadmap-label planned-label">Planned</p>
						<ul>
							<li>MM Exposure Analyzer</li>
							<li>MM Patch Planner</li>
						</ul>
					</div>

					<div class="roadmap-group">
						<p class="roadmap-label research-label">Research</p>
						<ul>
							<li>MM Attack Path Explorer</li>
						</ul>
					</div>

					<div class="hero-stats" aria-label="Statuts de la suite">
						<div class="stat-released">
							<strong>3</strong>
							<span>Released</span>
						</div>
						<div class="stat-development">
							<strong>1</strong>
							<span>In Development</span>
						</div>
						<div class="stat-planned">
							<strong>2</strong>
							<span>Planned</span>
						</div>
						<div class="stat-research">
							<strong>1</strong>
							<span>Research</span>
						</div>
					</div>

					<div class="latest-update">
						<div class="latest-update-head">
							<div>
								<p class="latest-kicker">Latest update</p>
								<h2>MM IOC Analyzer</h2>
							</div>

							<span class="development-pill">In Development</span>
						</div>

						<p class="latest-copy">
							Le prochain produit de la suite transformera des blocs de texte bruts
							en indicateurs de compromission structurés, validés et prêts à être exploités.
						</p>

						<div class="delivery-steps" aria-label="Étapes de conception du produit">
							<span class="step done">Product definition</span>
							<span class="step active">UX design</span>
							<span class="step">MVP development</span>
						</div>
					</div>
					<div class="roadmap-author">
						<div class="author-mark">MM</div>

						<div>
							<p>Designed &amp; built by <strong>Marc Michon</strong></p>
							<span>Cybersecurity Engineer</span>
						</div>

						<div class="author-note">
							<p>Made for the field.</p>
							<span>Built for impact.</span>
						</div>
					</div>
				</aside>
			</section>

			<section class="roadmap-section" id="roadmap">
				<div class="section-heading">
					<div>
						<p class="section-kicker">Product Roadmap</p>
						<h2>Une suite en évolution continue.</h2>
					</div>

					<p>
						Les outils publiés restent accessibles immédiatement. Les prochaines
						briques sont présentées selon leur phase de conception et de développement.
					</p>
				</div>

				<div class="status-legend" aria-label="Légende des statuts">
					{
						statusLegend.map((item) => (
							<span class={`legend-item status-${item.status}`}>
								<i></i>
								{item.label}
							</span>
						))
					}
				</div>

				<div class="products-grid">
					{
						products.map((product) =>
							product.href ? (
								<a href={product.href} class={`product-card status-${product.status}`}>
									<div class="product-visual">
										<img src={product.image} alt="" loading="lazy" decoding="async" />
									</div>

									<div class="product-content">
										<div class="product-meta">
											<span class="product-category">{product.category}</span>
											<span class="product-version">{product.version}</span>
										</div>

										<h3>
											<span class="mm-signature">MM</span>
											{product.name.replace(/^MM\s+/, '')}
										</h3>
										<p>{product.description}</p>

										<div class="product-footer">
											<span class="status-badge">
												<i></i>
												{product.statusLabel}
											</span>

											<span class="product-link">Ouvrir l’outil ↗</span>
										</div>
									</div>
								</a>
							) : (
								<article class={`product-card roadmap-card status-${product.status}`}>
									<div class="roadmap-visual" aria-hidden="true">
										<span>{product.icon}</span>
										<div class="roadmap-lines"></div>
									</div>

									<div class="product-content">
										<div class="product-meta">
											<span class="product-category">{product.category}</span>
											<span class="product-version">{product.version}</span>
										</div>

										<h3>
											<span class="mm-signature">MM</span>
											{product.name.replace(/^MM\s+/, '')}
										</h3>
										<p>{product.description}</p>

										<div class="product-footer">
											<span class="status-badge">
												<i></i>
												{product.statusLabel}
											</span>

											<span class="roadmap-note">Roadmap produit</span>
										</div>
									</div>
								</article>
							)
						)
					}
				</div>
			</section>

			<section class="principles-section">
				<div class="principles-intro">
					<p class="section-kicker">Product Principles</p>
					<h2>Une philosophie commune à toute la suite.</h2>
				</div>

				<div class="principles-grid">
					<article>
						<span>01</span>
						<h3>Le terrain avant la théorie</h3>
						<p>Chaque outil part d’un problème opérationnel réellement rencontré.</p>
					</article>

					<article>
						<span>02</span>
						<h3>Une décision en quelques secondes</h3>
						<p>L’interface doit réduire la complexité sans masquer le raisonnement.</p>
					</article>

					<article>
						<span>03</span>
						<h3>Zéro configuration inutile</h3>
						<p>Coller, analyser, comprendre et exporter : le parcours doit rester immédiat.</p>
					</article>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	:global(body) {
		margin: 0;
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(430px, 0.92fr);
		align-items: stretch;
		gap: 2.4rem;
		margin-bottom: 4rem;
		padding: 2rem;
		color: white;
		background:
			radial-gradient(circle at 84% 8%, rgba(37, 99, 235, 0.22), transparent 24rem),
			linear-gradient(135deg, #020817 0%, #06142d 58%, #031b4d 100%);
		border: 1px solid rgba(96, 165, 250, 0.16);
		border-radius: 28px;
		box-shadow: 0 24px 60px rgba(2, 8, 23, 0.22);
	}

	.hero-summary {
		display: flex;
		min-width: 0;
		flex-direction: column;
		justify-content: center;
		padding: 1.1rem 1rem 1rem;
	}

	.eyebrow,
	.section-kicker {
		margin: -0.35rem 0 0.55rem;
		color: #60a5fa;
		font-size: 0.75rem;
		font-weight: 900;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.eyebrow::after {
		display: block;
		width: 42px;
		height: 2px;
		margin-top: 0.75rem;
		content: "";
		background: linear-gradient(90deg, #38bdf8, transparent);
		border-radius: 999px;
	}

	.hero-summary > * {
		position: relative;
		z-index: 1;
	}

	.suite-brand-visual {
		position: relative;
		width: min(100%, 720px);
		margin-top: 0.85rem;
		background: transparent;
	}

	.suite-brand-visual::after {
		position: absolute;
		inset: 10% 5%;
		z-index: 0;
		content: "";
		background: radial-gradient(circle, rgba(37, 99, 235, 0.16), transparent 66%);
		filter: blur(26px);
		pointer-events: none;
	}

	.suite-brand-visual img {
		position: relative;
		z-index: 1;
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
	}

	.hero-lead {
		max-width: 760px;
		margin: 1.25rem 0 0;
		color: white;
		font-size: 1.12rem;
		font-weight: 800;
		line-height: 1.55;
	}

	.hero-copy {
		max-width: 760px;
		margin: 0.9rem 0 0;
		color: #cbd5e1;
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.hero-actions {
		margin-top: 2rem;
	}

	.primary-action {
		display: inline-flex;
		min-height: 42px;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 0.95rem;
		color: white;
		font-weight: 850;
		text-decoration: none;
		background: #2563eb;
		border-radius: 999px;
		box-shadow: 0 12px 26px rgba(37, 99, 235, 0.26);
		transition:
			transform 0.2s ease,
			background 0.2s ease;
	}

	.primary-action:hover {
		transform: translateY(-2px);
		background: #1d4ed8;
	}

	.hero-roadmap .hero-stats {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.5rem;
		margin-top: 0.8rem;
		padding-top: 0.9rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.hero-roadmap .hero-stats div {
		position: relative;
		padding: 0.62rem 0.65rem;
		background: rgba(255, 255, 255, 0.045);
		border: 1px solid rgba(147, 197, 253, 0.14);
		border-radius: 14px;
	}

	.hero-roadmap .hero-stats div::before {
		position: absolute;
		top: 50%;
		left: 0.65rem;
		width: 7px;
		height: 7px;
		content: "";
		background: #60a5fa;
		border-radius: 50%;
		transform: translateY(-50%);
	}

	.hero-roadmap .hero-stats strong {
		display: block;
		margin-left: 1rem;
		font-size: 1.2rem;
	}

	.hero-roadmap .hero-stats span {
		display: block;
		margin-top: 0.15rem;
		margin-left: 1rem;
		color: #93c5fd;
		font-size: 0.61rem;
		font-weight: 850;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.stat-released::before {
		background: #22c55e !important;
	}

	.stat-development::before {
		background: #fb923c !important;
	}

	.stat-planned::before {
		background: #60a5fa !important;
	}

	.stat-research::before {
		background: #c084fc !important;
	}

	.hero-roadmap .latest-update {
		margin-top: 0.7rem;
		padding: 1rem;
		background:
			radial-gradient(circle at 90% 10%, rgba(37, 99, 235, 0.15), transparent 11rem),
			rgba(255, 255, 255, 0.035);
		border: 1px solid rgba(96, 165, 250, 0.16);
		border-radius: 16px;
	}

	.latest-update-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.latest-kicker {
		margin: 0 0 0.24rem;
		color: #60a5fa;
		font-size: 0.6rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.latest-update h2 {
		margin: 0;
		color: white;
		font-size: 1.12rem;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.development-pill {
		display: inline-flex;
		align-items: center;
		min-height: 25px;
		padding: 0.28rem 0.52rem;
		color: #fdba74;
		font-size: 0.58rem;
		font-weight: 900;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		background: rgba(234, 88, 12, 0.1);
		border: 1px solid rgba(251, 146, 60, 0.26);
		border-radius: 999px;
		white-space: nowrap;
	}

	.latest-copy {
		margin: 0.6rem 0 0;
		color: #cbd5e1;
		font-size: 0.76rem;
		line-height: 1.5;
	}

	.delivery-steps {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.45rem;
		margin-top: 0.72rem;
	}

	.step {
		position: relative;
		padding: 0.5rem 0.42rem 0.5rem 1.3rem;
		color: #64748b;
		font-size: 0.6rem;
		font-weight: 800;
		line-height: 1.3;
		background: rgba(2, 8, 23, 0.3);
		border: 1px solid rgba(148, 163, 184, 0.1);
		border-radius: 10px;
	}

	.step::before {
		position: absolute;
		top: 50%;
		left: 0.48rem;
		width: 7px;
		height: 7px;
		content: "";
		background: #475569;
		border-radius: 50%;
		transform: translateY(-50%);
	}

	.step.done {
		color: #bbf7d0;
	}

	.step.done::before {
		background: #22c55e;
		box-shadow: 0 0 10px rgba(34, 197, 94, 0.35);
	}

	.step.active {
		color: #fed7aa;
	}

	.step.active::before {
		background: #fb923c;
		box-shadow: 0 0 10px rgba(251, 146, 60, 0.35);
	}

	.hero-roadmap {
		display: flex;
		min-width: 0;
		height: 100%;
		flex-direction: column;
		padding: 1.15rem;
		background:
			linear-gradient(180deg, rgba(7, 21, 49, 0.96), rgba(3, 15, 38, 0.96));
		border: 1px solid rgba(147, 197, 253, 0.16);
		border-radius: 20px;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
	}

	.hero-roadmap-head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}

	.hero-roadmap-head p,
	.hero-roadmap-head span {
		margin: 0;
	}

	.hero-roadmap-head p {
		font-weight: 900;
	}

	.hero-roadmap-head span {
		color: #60a5fa;
		font-size: 0.66rem;
		font-weight: 850;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.roadmap-group {
		padding: 0.72rem 0;
		border-bottom: 1px solid rgba(255, 255, 255, 0.07);
	}

	.roadmap-label {
		margin: 0 0 0.48rem;
		font-size: 0.64rem;
		font-weight: 900;
		letter-spacing: 0.11em;
		text-transform: uppercase;
	}

	.released-label {
		color: #4ade80;
	}

	.development-label {
		color: #fb923c;
	}

	.planned-label {
		color: #60a5fa;
	}

	.research-label {
		color: #c084fc;
	}

	.hero-roadmap ul {
		display: grid;
		gap: 0.34rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.hero-roadmap li {
		position: relative;
		padding-left: 1rem;
		color: #dbeafe;
		font-size: 0.82rem;
		font-weight: 750;
	}

	.hero-roadmap li::before {
		position: absolute;
		top: 0.62em;
		left: 0;
		width: 5px;
		height: 5px;
		content: "";
		background: #60a5fa;
		border-radius: 50%;
	}

	.roadmap-author {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.8rem;
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 0.08);
	}

	.author-mark {
		display: grid;
		width: 42px;
		height: 42px;
		place-items: center;
		color: white;
		font-size: 0.82rem;
		font-weight: 950;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(147, 197, 253, 0.35);
		clip-path: polygon(25% 6%, 75% 6%, 100% 50%, 75% 94%, 25% 94%, 0 50%);
	}

	.roadmap-author p,
	.roadmap-author span {
		margin: 0;
	}

	.roadmap-author p {
		color: #dbeafe;
		font-size: 0.74rem;
	}

	.roadmap-author span {
		color: #94a3b8;
		font-size: 0.68rem;
	}

	.author-note {
		text-align: right;
	}

	.author-note p {
		color: #94a3b8;
		font-size: 0.7rem;
	}

	.author-note span {
		display: block;
		margin-top: 0.14rem;
	}

	.roadmap-section {
		margin-bottom: 4rem;
	}

	.section-heading {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
		align-items: end;
		gap: 3rem;
		margin-bottom: 1.5rem;
	}

	.section-heading h2,
	.principles-intro h2 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(2.2rem, 4vw, 3.4rem);
		line-height: 1;
		letter-spacing: -0.045em;
	}

	.section-heading > p {
		max-width: 680px;
		margin: 0;
		color: #64748b;
		font-size: 1rem;
		line-height: 1.7;
	}

	.status-legend {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-bottom: 1.5rem;
	}

	.legend-item,
	.status-badge {
		display: inline-flex;
		align-items: center;
