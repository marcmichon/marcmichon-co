---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`Labs | ${SITE_TITLE}`}
			description="Des outils interactifs pour raisonner sur le risque, l’exposition et les opérations cybersécurité."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<p class="tag">LABS</p>
				<h1>Outils interactifs cybersécurité</h1>
				<p>
					Des mini-outils pour explorer, visualiser et raisonner sur le risque,
					l’exposition et les opérations de sécurité.
				</p>
			</section>

			<section class="labs-grid">
				<a href="/labs/risk-matrix" class="lab-card">
					<p>RISK MANAGEMENT</p>
					<h2>MM Risk Score</h2>
					<span>Impact × Probabilité → niveau de risque</span>
				</a>

				<article class="lab-grid">
					<a href="/labs/cvss-calculator" class="lab-card">
					<p>VULNERABILITY MANAGEMENT</p>
					<h2>CVSS Calculator</h2>
					<span>Construisez un vecteur CVSS v4.0</span>
					</a>
				</article>

				<article class="lab-grid">
					<a href="/labs/vulnerability-explorer" class="lab-card">
					<p>VULNERABILITY INTELLIGENCE</p>
					<h2>CVE vs Priorité</h2>
					<span>Transformez une CVE en priorité exploitable</span>
					</a>
				</article>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.hero {
		margin-bottom: 3rem;
		padding: 4rem;
		border-radius: 34px;
		color: white;
		background:
			radial-gradient(circle at 80% 0%, rgba(37,99,235,.24), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		box-shadow: 0 25px 70px rgba(2,8,23,.22);
	}

	.tag {
		color: #60a5fa;
		font-weight: 900;
		font-size: .85rem;
		letter-spacing: .16em;
		text-transform: uppercase;
	}

	h1 {
		margin: 1rem 0 1.5rem;
		color: white;
		font-size: 4.5rem;
		line-height: .95;
		letter-spacing: -0.06em;
	}

	.hero p:last-child {
		max-width: 800px;
		color: #dbeafe;
		font-size: 1.25rem;
		line-height: 1.75;
	}

	.labs-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.lab-card {
		display: block;
		min-height: 260px;
		padding: 2rem;
		border-radius: 28px;
		background: white;
		border: 1px solid #e5e7eb;
		text-decoration: none;
		box-shadow: 0 18px 45px rgba(15,23,42,.05);
		transition: all .25s ease;
	}

	.lab-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 25px 60px rgba(15,23,42,.12);
	}

	.lab-card p {
		color: #2563eb;
		font-size: .8rem;
		font-weight: 900;
		letter-spacing: .12em;
		text-transform: uppercase;
	}

	.lab-card h2 {
		color: #0f172a;
		font-size: 2rem;
		line-height: 1.05;
		letter-spacing: -0.04em;
	}

	.lab-card span {
		color: #64748b;
		font-weight: 700;
	}

	.disabled {
		opacity: .55;
	}

	@media (max-width: 900px) {
		main {
			width: min(100% - 2rem, 1320px);
		}

		.hero {
			padding: 2.5rem 1.5rem;
			border-radius: 24px;
		}

		h1 {
			font-size: 3rem;
		}

		.labs-grid {
			grid-template-columns: 1fr;
		}
	}
</style>