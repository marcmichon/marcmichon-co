---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroPremium from '../components/HeroPremium.astro';
import StatsBar from '../components/StatsBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />

		<HeroPremium />

		<StatsBar />
<main>
	<section>

		<h2>Domaines d’intervention</h2>

		<div class="cards">

			<div class="card">
				<h3>Vulnerability Management</h3>
				<p>
					Intégration de solutions, structuration,
					tagging, priorisation et remédiation.
				</p>
			</div>

			<div class="card">
				<h3>Exposure Management</h3>
				<p>
					Visibilité, surface d’attaque
					et contexte de risque.
				</p>
			</div>

			<div class="card">
				<h3>Threat Intelligence</h3>
				<p>
					Enrichissement, IOC,
					contexte menace et investigation.
				</p>
			</div>

			<div class="card">
				<h3>Security Operations</h3>
				<p>
					SIEM, SOAR, détection
					et exploitation opérationnelle.
				</p>
			</div>

			<div class="card">
				<h3>MSSP / RUN</h3>
				<p>
					Maintien en condition opérationnelle
					et support client.
				</p>
			</div>

		</div>

	</section>
</main>

		<Footer />
	</body>
</html>

<style>
main {
	width: 100%;
	max-width: 1180px;
	margin: 0 auto;
	padding: 2rem 1.5rem 2rem;
}

h1 {
	font-size: 5rem;
}

.hero-grid {
	grid-template-columns: 1.35fr 0.75fr 0.65fr;
}

.stats-bar {
	margin: -3rem auto 1.5rem;
}

section {
	margin-bottom: 4rem;
}

section:last-child {
	margin-bottom: 1rem;
}

h2 {
	font-size: 2.5rem;
	font-weight: 900;
	margin-bottom: 2rem;
}

/* ==========================
   EXPERTISES
========================== */

.cards {
	display: grid;
	grid-template-columns: repeat(5, 1fr);
	gap: 1.5rem;
	width: 100%;
}

.card {
	padding: 1.4rem;
	border: 1px solid #e5e7eb;
	border-radius: 16px;
	background: white;
	min-height: 170px;
	transition: all .2s ease;
}

.card:hover {
	transform: translateY(-4px);
	box-shadow: 0 10px 30px rgba(0,0,0,.08);
}

.card h3 {
	margin: 0 0 .75rem 0;
	font-size: 1rem;
	font-weight: 700;
	line-height: 1.3;
}

.card p {
	margin: 0;
	font-size: .95rem;
	line-height: 1.5;
	color: #475569;
}

@media (max-width: 1200px) {
	.cards {
		grid-template-columns: repeat(3, 1fr);
	}
}

@media (max-width: 768px) {
	.cards {
		grid-template-columns: repeat(2, 1fr);
	}
}

@media (max-width: 520px) {
	.cards {
		grid-template-columns: 1fr;
	}
}
</style>