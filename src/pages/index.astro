---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
	<p class="eyebrow">Marc Michon</p>

	<h1>Cybersecurity Engineer</h1>

	<p class="subtitle">Rapid7 Tech Champion</p>

	<p class="intro">
		J’aide les organisations à améliorer leur visibilité...
	</p>

	<div class="badges">
		<span>+10 ans d'expérience</span>
		<span>Rapid7 Tech Champion</span>
		<span>Exposure Management</span>
		<span>Threat Intelligence</span>
		<span>MSSP</span>
		<span>Architecture Sécurité</span>
	</div>
</section>

			<section>
				<h2>Expertises</h2>

				<ul>
					<li>Vulnerability Management</li>
					<li>Exposure Management</li>
					<li>Threat Intelligence</li>
					<li>Security Operations</li>
					<li>MSSP / Services managés</li>
				</ul>
			</section>

			<section>
				<h2>Technologies</h2>

				<ul>
					<li>Rapid7 InsightVM / InsightIDR / Exposure Command</li>
					<li>Recorded Future</li>
					<li>SentinelOne</li>
					<li>Nutanix</li>
					<li>BeyondTrust</li>
					<li>Palo Alto Networks</li>
				</ul>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 960px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.hero {
		margin-bottom: 4rem;
	}

	.eyebrow {
		color: var(--accent);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		font-size: 4rem;
		margin: 0;
		line-height: 1.05;
	}

	.subtitle {
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 1rem;
	}

	.intro {
		font-size: 1.2rem;
		max-width: 720px;
	}

	.badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.badges span {
		padding: 0.5rem 0.9rem;
		border-radius: 999px;
		background: #eef2ff;
		color: #3b5bdb;
		font-size: 0.9rem;
		font-weight: 600;
		border: 1px solid #dbe4ff;
	}

	section {
		margin-bottom: 3rem;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	li {
		margin-bottom: 0.5rem;
	}
</style>