---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroPremium from '../components/HeroPremium.astro';
import StatsBar from '../components/StatsBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />

		<HeroPremium />

		<StatsBar />

		<main>
			<section>
				<h2>Domaines d’intervention</h2>

				<div class="cards">
					<div class="card">
						<img src="/Images/vulnmngt.png" alt="" class="card-image" />
						<h3>Vulnerability Management</h3>
						<p>Intégration de solutions, structuration, tagging, priorisation et remédiation.</p>
					</div>

					<div class="card">
						<img src="/Images/exposurmngt.png" alt="" class="card-image" />
						<h3>Exposure Management</h3>
						<p>Visibilité, surface d’attaque et contexte de risque.</p>
					</div>

					<div class="card">
						<img src="/Images/cti.png" alt="" class="card-image" />
						<h3>Threat Intelligence</h3>
						<p>Enrichissement, IOC, contexte menace et investigation.</p>
					</div>

					<div class="card">
						<img src="/Images/secops.png" alt="" class="card-image" />
						<h3>Security Operations</h3>
						<p>SIEM, SOAR, détection et exploitation opérationnelle.</p>
					</div>

					<div class="card">
						<img src="/Images/mssp.png" alt="" class="card-image" />
						<h3>MSSP / RUN</h3>
						<p>Maintien en condition opérationnelle et support client.</p>
					</div>
				</div>
			</section>

			<section class="articles-section">
				<div class="section-header">
					<div>
						<p class="section-tag"></p>
						<h2>Retours d’expérience sur le terrain</h2>
					</div>

					<a href="/notes-de-terrain" class="see-all">Voir tous les articles →</a>
				</div>

				<div class="articles-grid">

<a href="/articles/angles-morts-console-edr" class="article-card">
	<div class="article-image">
		<img
			src="/Images/edr-console-angles-morts.png"
			alt="Les angles morts d’une console EDR"
		/>
	</div>

	<div class="article-content">
		<p class="article-category">
			ENDPOINT SECURITY
		</p>

		<h3>
			Les angles morts d’une console EDR
		</h3>

		<p>
			Pourquoi une console au vert ne garantit pas que votre niveau de sécurité est réellement bon.
		</p>

		<span>⏱ 7 min de lecture</span>
	</div>
</a>

					<a href="/articles/ce-que-votre-edr-ne-voit-pas" class="article-card">
						<div class="article-image">
							<img src="/Images/edr-assets.png" alt="Votre EDR voit-il vraiment tout ?" />
						</div>

						
						<div class="article-content">
							<p class="article-category">ENDPOINT SECURITY</p>
							<h3>Votre EDR voit-il vraiment tout ?</h3>
							<p>
								Un EDR protège uniquement les équipements qu'il connaît.
								Les équipements absents de la console constituent souvent des angles morts de sécurité.
							</p>
							<span>⏱ 3 min de lecture</span>
						</div>
					</a>

					<a href="/articles/endpoint-protege-endpoint-securise" class="article-card">
						<div class="article-image">
							<img src="/Images/assetsinconnus.png" alt="" />
						</div>

						<div class="article-content">
							<p class="article-category">ENDPOINT SECURITY</p>
							<h3>Pourquoi un endpoint protégé n'est pas forcément un endpoint sécurisé</h3>
							<p>
								Installer un agent de protection est une étape essentielle.
								Mais la sécurité d’un endpoint ne se résume jamais à la présence d’un EDR.
							</p>
							<span>⏱ 4 min de lecture</span>
						</div>
					</a>

					<a href="/articles/tagging-vulnerability-management" class="article-card">
						<div class="article-image">
							<img src="/Images/tagging.png" alt="" />
						</div>

						<div class="article-content">
							<p class="article-category">VM FUNDAMENTALS</p>
							<h3>Pourquoi le tagging est une fonctionnalité sous-estimée</h3>
							<p>Transformer une donnée brute en contexte exploitable.</p>
							<span>⏱ 4 min de lecture</span>
						</div>
					</a>

			
				</div>
			</section>


			

			<section class="tools-section">
				<div class="tools-shell">
					<div class="tools-sidebar">
						<p class="tools-kicker">Boîte à outils cybersécurité</p>
						<h2>MM Security Intelligence</h2>

						<p class="tools-intro">
							Des outils développés à partir de problématiques rencontrées sur le terrain
							pour aider les équipes sécurité à analyser, prioriser et prendre de meilleures décisions.
						</p>
					</div>

					<div class="tools-list">
						<a href="/labs/risk-matrix" class="tool-row">
							<div class="tool-banner-wrap">
								<img
									src="/Images/tools/home/risk-score-home.png"
									class="tool-banner"
									alt=""
									loading="lazy"
									decoding="async"
								/>
							</div>

							<div class="tool-body">
								<p class="tool-category">Risk Management</p>
								<h3>MM Risk Score</h3>
								<p>Le risque métier, pas uniquement le risque technique.</p>
							</div>

							<span class="tool-arrow" aria-hidden="true">↗</span>
						</a>

						<a href="/labs/cvss-calculator" class="tool-row">
							<div class="tool-banner-wrap">
								<img
									src="/Images/tools/home/cvss-calculator-home.png"
									class="tool-banner"
									alt=""
									loading="lazy"
									decoding="async"
								/>
							</div>

							<div class="tool-body">
								<p class="tool-category">Vulnerability Management</p>
								<h3>CVSS Calculator</h3>
								<p>Calcul CVSS v4 conforme au standard FIRST.</p>
							</div>

							<span class="tool-arrow" aria-hidden="true">↗</span>
						</a>

						<a href="/labs/vulnerability-explorer" class="tool-row">
							<div class="tool-banner-wrap">
								<img
									src="/Images/tools/home/vulnerability-explorer-home.png"
									class="tool-banner"
									alt=""
									loading="lazy"
									decoding="async"
								/>
							</div>

							<div class="tool-body">
								<p class="tool-category">Vulnerability Intelligence</p>
								<h3>Vulnerability Explorer</h3>
								<p>Corrélation CVE • KEV • EPSS • CISA et bien plus.</p>
							</div>

							<span class="tool-arrow" aria-hidden="true">↗</span>
						</a>

						<div class="tools-footer">
							<a href="/labs" class="tools-button">Explorer tous les outils →</a>
						</div>
					</div>
				</div>
			</section>

			<section class="certifications-section">
				<h2>Certifications</h2>

				<div class="certifications-grid">
					<div class="cert-card">
						<img src="/Images/techchampionr7.png" alt="Rapid7 Tech Champion" />
						<h3>Rapid7 Tech Champion</h3>
					</div>

					<div class="cert-card">
						<img src="/Images/RSTPEC.png" alt="RTSP Exposure Command" />
						<h3>RTSP Exposure Command</h3>
					</div>

					<div class="cert-card">
						<img src="/Images/RSTPIVM.png" alt="RTSP InsightVM" />
						<h3>RTSP InsightVM</h3>
					</div>

					<div class="cert-card">
						<img src="/Images/RSTPIC.png" alt="RTSP Incident Command" />
						<h3>RTSP Incident Command</h3>
					</div>

					<div class="cert-card">
						<img src="/Images/iso_27001_02-1024x704.png" alt="ISO 27001 Foundation" />
						<h3>ISO 27001 Foundation</h3>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>


<style>
	:global(body) {
		margin: 0;
		background: #ffffff;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 2rem 0 3rem;
	}

	section {
		margin-bottom: 3rem;
	}

	section:last-child {
		margin-bottom: 1rem;
	}

	h1 {
		font-size: 5rem;
	}

	h2 {
		margin: 0 0 1.5rem;
		font-size: 2.5rem;
		font-weight: 900;
		line-height: 1.1;
	}

	.hero-grid {
		grid-template-columns: 1.35fr 0.75fr 0.65fr;
	}

	.stats-bar {
		margin: -3rem auto 1.5rem;
	}

	/* Domaines d'intervention */

	.cards {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
		width: 100%;
	}

	.card {
		min-width: 0;
		min-height: 305px;
		overflow: hidden;
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 20px;
		box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}

	.card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 50px rgba(15, 23, 42, 0.1);
	}

	.card-image {
		display: block;
		width: 100%;
		height: 160px;
		object-fit: cover;
	}

	.card h3 {
		margin: 0;
		padding: 1.25rem 1.25rem 0;
		color: #0f172a;
		font-size: 1rem;
		font-weight: 800;
		line-height: 1.35;
	}

	.card p {
		margin: 0;
		padding: 0.85rem 1.25rem 1.5rem;
		color: #475569;
		font-size: 0.86rem;
		line-height: 1.5;
	}

	/* Retours d'expérience */

	.articles-section {
		margin-top: 3.5rem;
	}

	.section-header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1.15rem;
	}

	.section-header h2 {
		margin-bottom: 0;
	}

	.section-tag {
		margin: 0;
	}

	.see-all {
		color: #2563eb;
		font-weight: 700;
		text-decoration: none;
		white-space: nowrap;
	}

	.articles-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.article-card {
		display: flex;
		min-width: 0;
		min-height: 305px;
		flex-direction: column;
		overflow: hidden;
		color: inherit;
		text-decoration: none;
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}

	.article-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 50px rgba(15, 23, 42, 0.1);
	}

	.article-image {
		width: 100%;
		height: 112px;
		flex: 0 0 112px;
		overflow: hidden;
	}

	.article-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.35s ease;
	}

	.article-card:hover .article-image img {
		transform: scale(1.035);
	}

	.article-content {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 1rem;
	}

	.article-category {
		margin: 0 0 0.55rem;
		color: #2563eb;
		font-size: 0.62rem;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.article-card h3 {
		margin: 0 0 0.7rem;
		color: #0f172a;
		font-size: 0.98rem;
		line-height: 1.35;
	}

	.article-content p:not(.article-category) {
		flex: 1;
		margin: 0 0 0.65rem;
		color: #475569;
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.article-content span {
		margin-top: auto;
		color: #64748b;
		font-size: 0.72rem;
		font-weight: 600;
	}

	/* MM Security Intelligence */

	.tools-section {
		margin-top: 3.5rem;
	}

	.tools-shell {
		display: grid;
		grid-template-columns: 280px minmax(0, 1fr);
		gap: 2rem;
		padding: 1.75rem;
		overflow: hidden;
		background:
			radial-gradient(
				circle at 88% 8%,
				rgba(37, 99, 235, 0.18),
				transparent 24rem
			),
			linear-gradient(135deg, #020817 0%, #06142d 58%, #031b4d 100%);
		border-radius: 22px;
		box-shadow: 0 20px 50px rgba(2, 8, 23, 0.17);
	}

	.tools-sidebar {
		min-width: 0;
	}

	.tools-kicker {
		margin: 0 0 0.45rem;
		color: #60a5fa;
		font-size: 0.68rem;
		font-weight: 900;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.tools-sidebar h2 {
		margin: 0 0 0.9rem;
		color: white;
		font-size: 1.9rem;
		line-height: 1.05;
	}

	.tools-intro {
		margin: 0;
		color: #cbd5e1;
		font-size: 0.84rem;
		line-height: 1.65;
	}

	.tools-list {
		display: flex;
		min-width: 0;
		flex-direction: column;
	}

	.tool-row {
		display: grid;
		grid-template-columns: 270px minmax(0, 1fr) 28px;
		align-items: center;
		gap: 1.15rem;
		min-width: 0;
		padding: 0.8rem 0;
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		transition: transform 0.2s ease;
	}

	.tool-row:first-child {
		padding-top: 0;
	}

	.tool-row:last-of-type {
		border-bottom: 0;
	}

	.tool-row:hover {
		transform: translateX(4px);
	}

	.tool-banner-wrap {
		width: 270px;
		height: 90px;
		overflow: hidden;
		background: #020817;
		border-radius: 12px;
	}

	.tool-banner {
		display: block;
		width: 270px;
		height: 90px;
		object-fit: cover;
		object-position: center;
		transform: none;
		filter: none;
	}

	.tool-body {
		min-width: 0;
	}

	.tool-category {
		margin: 0 0 0.22rem;
		color: #60a5fa;
		font-size: 0.62rem;
		font-weight: 900;
		letter-spacing: 0.1em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.tool-body h3 {
		margin: 0 0 0.28rem;
		color: white;
		font-size: 1.05rem;
		line-height: 1.15;
		letter-spacing: -0.025em;
	}

	.tool-body > p:not(.tool-category) {
		margin: 0;
		color: #cbd5e1;
		font-size: 0.78rem;
		line-height: 1.45;
	}

	.tool-arrow {
		color: #60a5fa;
		font-size: 1.05rem;
		font-weight: 800;
		transition: transform 0.2s ease;
	}

	.tool-row:hover .tool-arrow {
		transform: translate(2px, -2px);
	}

	.tools-footer {
		display: flex;
		justify-content: flex-start;
		margin-top: 1rem;
	}

	.tools-button {
		display: inline-flex;
		min-height: 36px;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 0.9rem;
		color: white;
		font-size: 0.78rem;
		font-weight: 850;
		text-decoration: none;
		background: #2563eb;
		border-radius: 999px;
		box-shadow: 0 10px 22px rgba(37, 99, 235, 0.22);
		transition:
			transform 0.2s ease,
			background 0.2s ease;
	}

	.tools-button:hover {
		transform: translateY(-2px);
		background: #1d4ed8;
	}

	/* Certifications */

	.certifications-grid {
		display: grid;
		grid-template-columns: repeat(5, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.cert-card {
		display: flex;
		min-height: 220px;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 1.2rem;
		text-align: center;
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 16px;
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}

	.cert-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
	}

	.cert-card img {
		width: auto;
		height: auto;
		max-width: 120px;
		max-height: 80px;
		margin-bottom: 1rem;
		object-fit: contain;
	}

	.cert-card h3 {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.4;
	}

	@media (max-width: 1200px) {
		.cards {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.articles-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.tools-shell {
			grid-template-columns: 1fr;
		}

		.tool-row {
			grid-template-columns: 270px minmax(0, 1fr) 28px;
		}

		.certifications-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 768px) {
		main {
			width: min(100% - 2rem, 1320px);
			padding: 1.5rem 0 3rem;
		}

		.cards,
		.articles-grid,
		.certifications-grid {
			grid-template-columns: 1fr;
		}

		.section-header {
			display: block;
		}

		.see-all {
			display: inline-block;
			margin-top: 0.75rem;
		}

		h2 {
			font-size: 2rem;
		}

		.tools-shell {
			grid-template-columns: 1fr;
			gap: 1.25rem;
			padding: 1.2rem;
			border-radius: 18px;
		}

		.tools-sidebar h2 {
			font-size: 1.6rem;
		}

		.tool-row {
			grid-template-columns: minmax(0, 1fr) 24px;
			gap: 0.75rem;
			padding: 0.85rem 0;
		}

		.tool-banner-wrap {
			grid-column: 1 / -1;
			width: 100%;
			height: auto;
			aspect-ratio: 3 / 1;
		}

		.tool-banner {
			width: 100%;
			height: 100%;
		}

		.tool-body {
			grid-column: 1;
		}

		.tool-arrow {
			grid-column: 2;
			grid-row: 2;
		}

		.certifications-section {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.card,
		.article-card,
		.article-image img,
		.tool-row,
		.tool-arrow,
		.tools-button,
		.cert-card {
			transition: none;
		}

		.card:hover,
		.article-card:hover,
		.tool-row:hover,
		.tools-button:hover,
		.cert-card:hover {
			transform: none;
		}

		.article-card:hover .article-image img {
			transform: none;
		}
	}
</style>
