---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroPremium from '../components/HeroPremium.astro';
import StatsBar from '../components/StatsBar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />

		<HeroPremium />

		<StatsBar />
<main>
	<section>

		<h2>Domaines d’intervention</h2>

		<div class="cards">

			<div class="card">
				<h3>Vulnerability Management</h3>
				<p>
					Intégration de solutions, structuration,
					tagging, priorisation et remédiation.
				</p>
			</div>

			<div class="card">
				<h3>Exposure Management</h3>
				<p>
					Visibilité, surface d’attaque
					et contexte de risque.
				</p>
			</div>

			<div class="card">
				<h3>Threat Intelligence</h3>
				<p>
					Enrichissement, IOC,
					contexte menace et investigation.
				</p>
			</div>

			<div class="card">
				<h3>Security Operations</h3>
				<p>
					SIEM, SOAR, détection
					et exploitation opérationnelle.
				</p>
			</div>

			<div class="card">
				<h3>MSSP / RUN</h3>
				<p>
					Maintien en condition opérationnelle
					et support client.
				</p>
			</div>

		</div>

	</section>

	<section class="articles-section">
	<div class="section-header">
		<div>
			<p class="section-tag">NOTES DE TERRAIN</p>
			<h2>Retours d’expérience sur le terrain</h2>
		</div>

		<a href="/notes-de-terrain" class="see-all">Voir tous les articles →</a>
	</div>

	<div class="articles-grid">
		<article class="article-card">
			
			<p class="article-category">VM FUNDAMENTALS</p>
			<h3>Pourquoi les programmes VM échouent rarement à cause du moteur de scan</h3>
			<p>Le vrai problème se situe souvent ailleurs : gouvernance, processus et remédiation.</p>
			<span>3 min de lecture</span>
		</article>

		<article class="article-card">
			<p class="article-category">VM FUNDAMENTALS</p>
			<h3>Pourquoi les assets inconnus détruisent votre visibilité sécurité</h3>
			<p>On ne protège pas ce qu'on ne connaît pas.</p>
			<span>4 min de lecture</span>
		</article>

		<article class="article-card">
			<p class="article-category">VM FUNDAMENTALS</p>
			<h3>Pourquoi le tagging est une fonctionnalité sous-estimée</h3>
			<p>Transformer une donnée brute en contexte exploitable.</p>
			<span>4 min de lecture</span>
		</article>

		<article class="article-card">
			<p class="article-category">VM FUNDAMENTALS</p>
			<h3>Une vulnérabilité critique détectée n’a jamais réduit le risque</h3>
			<p>Détecter n’est que la première étape.</p>
			<span>5 min de lecture</span>
		</article>
	</div>
</section>

<section>
	<h2>Certifications</h2>

	<div class="certifications-grid">

		<div class="cert-card">
			<img src="/Images/techchampionr7.png" alt="Rapid7 Tech Champion" />
			<h3>Rapid7 Tech Champion</h3>
		</div>

		<div class="cert-card">
			<img src="/Images/RSTPEC.png" alt="RTSP Exposure Command" />
			<h3>RTSP Exposure Command</h3>
		</div>

		<div class="cert-card">
			<img src="/Images/RSTPIVM.png" alt="RTSP InsightVM" />
			<h3>RTSP InsightVM</h3>
		</div>

		<div class="cert-card">
			<img src="/Images/RSTPIC.png" alt="RTSP Incident Command" />
			<h3>RTSP Incident Command</h3>
		</div>

		<div class="cert-card">
			<img src="/Images/iso_27001_02-1024x704.png" alt="ISO 27001 Foundation" />
			<h3>ISO 27001 Foundation</h3>
		</div>

	</div>
</section>
</main>

		<Footer />
	</body>
</html>

<style>
main {
	width: 100%;
	max-width: 1180px;
	margin: 0 auto;
	padding: 2rem 1.5rem 2rem;
}

h1 {
	font-size: 5rem;
}

.hero-grid {
	grid-template-columns: 1.35fr 0.75fr 0.65fr;
}

.stats-bar {
	margin: -3rem auto 1.5rem;
}

section {
	margin-bottom: 4rem;
}

section:last-child {
	margin-bottom: 1rem;
}

h2 {
	font-size: 2.5rem;
	font-weight: 900;
	margin-bottom: 2rem;
}

/* ==========================
   EXPERTISES
========================== */

.cards {
	display: grid;
	grid-template-columns: repeat(5, 1fr);
	gap: 1.5rem;
	width: 100%;
}

.card {
	padding: 1.4rem;
	border: 1px solid #e5e7eb;
	border-radius: 16px;
	background: white;
	min-height: 170px;
	transition: all .2s ease;
}

.card:hover {
	transform: translateY(-4px);
	box-shadow: 0 10px 30px rgba(0,0,0,.08);
}

.card h3 {
	margin: 0 0 .75rem 0;
	font-size: 1rem;
	font-weight: 700;
	line-height: 1.3;
}

.card p {
	margin: 0;
	font-size: .95rem;
	line-height: 1.5;
	color: #475569;
}

@media (max-width: 1200px) {
	.cards {
		grid-template-columns: repeat(3, 1fr);
	}
}

@media (max-width: 768px) {
	.cards {
		grid-template-columns: repeat(2, 1fr);
	}
}

@media (max-width: 520px) {
	.cards {
		grid-template-columns: 1fr;
	}
}

.articles-section {
	margin-top: 5rem;
}

.section-header {
	display: flex;
	justify-content: space-between;
	align-items: flex-end;
	gap: 2rem;
	margin-bottom: 2rem;
}

.section-tag,
.article-category {
	font-size: .8rem;
	font-weight: 800;
	letter-spacing: .08em;
	color: #2563eb;
	text-transform: uppercase;
}

.see-all {
	color: #2563eb;
	font-weight: 700;
	text-decoration: none;
}

.articles-grid {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 1.75rem;
}

.article-card {
	border: 1px solid #e5e7eb;
	border-radius: 18px;
	background: white;
	padding: 1.6rem;
	min-height: 280px;
	box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
	transition: all .2s ease;
}

.article-card:hover {
	transform: translateY(-4px);
	box-shadow: 0 16px 40px rgba(15, 23, 42, 0.1);
}

.article-card h3 {
	font-size: 1.15rem;
	line-height: 1.35;
	margin: .75rem 0 1rem;
}

.article-card p {
	color: #475569;
	line-height: 1.6;
}

.article-card span {
	display: block;
	margin-top: 1.25rem;
	font-size: .85rem;
	color: #64748b;
}

@media (max-width: 1100px) {
	.articles-grid {
		grid-template-columns: repeat(2, 1fr);
	}
}

@media (max-width: 640px) {
	.section-header {
		display: block;
	}

	.articles-grid {
		grid-template-columns: 1fr;
	}
}

.certifications {
	margin-top: 1rem;
	margin-bottom: 4rem;
}

.certifications .card {
	text-align: center;
	min-height: 140px;
	display: flex;
	flex-direction: column;
	justify-content: center;
}

.certifications .card h3 {
	font-size: 1.1rem;
	margin-bottom: .75rem;
}

.certifications .card p {
	font-size: .95rem;
	line-height: 1.5;
}

/* ==========================
   CERTIFICATIONS
========================== */

.certifications-grid {
	display: grid;
	grid-template-columns: repeat(5, 1fr);
	gap: 1.5rem;
	margin-top: 2rem;
}

.cert-card {
	background: white;
	border: 1px solid #e5e7eb;
	border-radius: 16px;
	padding: 1.5rem;

	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;

	text-align: center;
	min-height: 220px;
}

.cert-card:hover {
	transform: translateY(-4px);
	box-shadow: 0 10px 30px rgba(0,0,0,.08);
}

.cert-card img {
	max-width: 120px;
	max-height: 80px;
	width: auto;
	height: auto;
	object-fit: contain;
	margin-bottom: 1rem;
}

.cert-card h3 {
	margin: 0;
	font-size: 1rem;
	font-weight: 700;
	line-height: 1.4;
}
</style>