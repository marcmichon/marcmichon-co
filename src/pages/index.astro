---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
	<section class="hero">

	<div class="hero-content">

		<div class="hero-text">

			<h1>Marc Michon</h1>

			<p class="role">Cybersecurity Engineer</p>

			<div class="subtitle">
				<img src="/Images/R7.svg" alt="Rapid7" />
				<span>  Rapid7 Tech Champion</span>
			</div>

			<p class="intro">
				<strong>Architecture • Intégration • Exploitation</strong>
				<br /><br />
				Spécialiste des plateformes de détection,
				de gestion des vulnérabilités et de réduction
				de la surface d'attaque.
			</p>

		</div>

		<div class="hero-photo">
			<img src="/Images/moi.jpeg" alt="Marc Michon" />
		</div>

	</div>

</section>

			<section>

	<h2>Expertises</h2>

	<div class="cards">

		<div class="card">
			<h3>Vulnerability Management</h3>
			<p>Structuration de programmes VM et remédiation.</p>
		</div>

		<div class="card">
			<h3>Exposure Management</h3>
			<p>Réduction de la surface d'attaque.</p>
		</div>

		<div class="card">
			<h3>Threat Intelligence</h3>
			<p>Analyse et contextualisation des menaces.</p>
		</div>

		<div class="card">
			<h3>Security Operations</h3>
			<p>SOC, SIEM, SOAR et opérations de sécurité.</p>
		</div>

		<div class="card">
			<h3>MSSP</h3>
			<p>Services managés et accompagnement RUN.</p>
		</div>

	</div>

</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1120px;
		margin: 0 auto;
		padding: 5rem 1.5rem;
	}

	.hero {
		max-width: 900px;
		margin-bottom: 5rem;
	}

.hero h1 {
	font-size: 4.8rem;
	font-weight: 900;
	line-height: 0.95;
	margin: 0;
	letter-spacing: -0.04em;
}

.role {
	font-size: 2.3rem;
	font-weight: 700;
	color: #2563eb;
	line-height: 1.1;
	margin: 0.4rem 0 1rem 0;
}

.subtitle {
	font-size: 1.5rem;
	font-weight: 700;
	margin: 0 0 2rem 0;
	color: #1f2937;
}

.intro {
	font-size: 1.45rem;
	line-height: 1.8;
	max-width: 1000px;
	margin: 0;
	color: #273044;
}

	.badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	.badges span {
		padding: 0.55rem 0.95rem;
		border-radius: 999px;
		background: #eef2ff;
		color: #3056d3;
		font-size: 0.9rem;
		font-weight: 700;
		border: 1px solid #dbe4ff;
	}

	section {
		margin-bottom: 3rem;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	li {
		margin-bottom: 0.5rem;
	}
	.subtitle img {
	height: 20px;
	width: auto;
}

.subtitle {
	margin-top: 1rem;
	margin-bottom: 2rem;
}

.hero-content {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 4rem;
}

.hero-text {
	flex: 1;
}

.hero-photo img {
	width: 240px;
	height: 240px;
	object-fit: cover;
	border-radius: 20px;
	box-shadow: 0 10px 30px rgba(0,0,0,.15);
}

.cards {
	display: grid;
	grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
	gap: 1.5rem;
}

.card {
	padding: 1.5rem;
	border: 1px solid #e5e7eb;
	border-radius: 16px;
	background: white;
	transition: .2s;
}

.card:hover {
	transform: translateY(-3px);
	box-shadow: 0 8px 25px rgba(0,0,0,.08);
}

.card h3 {
	margin-top: 0;
	margin-bottom: .75rem;
	font-size: 1.2rem;
}

.card p {
	margin: 0;
	color: #475569;
	line-height: 1.6;
}
</style>