---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleHero from '../../components/article/ArticleHero.astro';
import ArticleLayout from '../../components/article/ArticleLayout.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const articles = await getCollection('articles');

	return articles.map((article) => ({
		params: { slug: article.id },
		props: { article },
	}));
}

const { article } = Astro.props;
const { Content } = await render(article);

const updated = article.data.updatedDate
	? `Mis à jour : ${article.data.updatedDate.toLocaleDateString('fr-FR', {
			month: 'long',
			year: 'numeric',
		})}`
	: `Publié : ${article.data.pubDate.toLocaleDateString('fr-FR', {
			month: 'long',
			year: 'numeric',
		})}`;

const toc = [
	{ id: 'pourquoi-cet-article', label: 'Pourquoi cet article ?' },
	{ id: 'le-vrai-probleme', label: 'Le vrai problème' },
	{ id: 'conclusion', label: 'Conclusion' },
];
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`${article.data.title} | ${SITE_TITLE}`}
			description={article.data.description}
		/>
	</head>

	<body>
		<Header />

		<main>
			<ArticleHero
				tag={article.data.category}
				title={article.data.title}
				subtitle={article.data.description}
				image={article.data.heroImage}
				readTime={article.data.readingTime ?? '5 min de lecture'}
				level={article.data.difficulty}
				updated={updated}
				technologies={article.data.technologies}
			/>

			<ArticleLayout toc={toc}>
				<Content />
			</ArticleLayout>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 2rem, 1320px);
		}
	}
</style>
