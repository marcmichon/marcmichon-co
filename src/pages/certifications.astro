---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`Certifications | ${SITE_TITLE}`}
			description="Certifications, reconnaissances techniques et écosystème technologique principal de Marc Michon, ingénieur cybersécurité."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="cert-hero">
				<p class="section-tag">CERTIFICATIONS</p>

				<h1>Validation technique & expertise terrain</h1>

				<p class="intro">
					Les certifications constituent un socle de connaissances. Les projets terrain
					permettent de transformer ces connaissances en compétences opérationnelles,
					exploitables et durables.
				</p>
			</section>

			<section class="featured">
				<div class="featured-card">
					<div class="featured-logo">
						<img src="/Images/R7.svg" alt="Rapid7" />
					</div>

					<div>
						<p class="section-tag">RECONNAISSANCE</p>
						<h2>Rapid7 Tech Champion</h2>

						<p>
							Reconnaissance technique Rapid7 Partner Program, orientée expertise,
							avant-vente, intégration, exploitation et accompagnement terrain.
						</p>

						<div class="featured-tags">
							<span>Rapid7</span>
							<span>Vulnerability Management</span>
							<span>Exposure Management</span>
							<span>Security Operations</span>
						</div>
					</div>
				</div>
			</section>

			<section class="cert-section">
				<div class="section-header">
					<h2>Certifications principales</h2>
					<p>Un socle technique centré sur les plateformes réellement utilisées sur le terrain.</p>
				</div>

				<div class="cert-grid">
					<article class="cert-card">
						<img src="/Images/RSTPIVM.png" alt="" />
						<h3>RTSP InsightVM</h3>
						<p>Déploiement, administration, structuration et optimisation InsightVM.</p>
					</article>

					<article class="cert-card">
						<img src="/Images/RSTPEC.png" alt="" />
						<h3>RTSP Exposure Command</h3>
						<p>Gestion de l’exposition, visibilité et réduction de la surface d’attaque.</p>
					</article>

					<article class="cert-card">
						<img src="/Images/RSTPIC.png" alt="" />
						<h3>RTSP Incident Command</h3>
						<p>Compréhension des capacités d’investigation, réponse et orchestration.</p>
					</article>

					<article class="cert-card">
						<img src="/Images/iso_27001_02-1024x704.png" alt="" />
						<h3>ISO 27001 Foundation</h3>
						<p>Fondamentaux du SMSI, gouvernance sécurité et amélioration continue.</p>
					</article>
				</div>
			</section>

			<section class="cert-timeline">
				<div class="timeline-header">
					<p class="section-tag">PROGRESSION</p>
					<h2>Une trajectoire orientée terrain</h2>
					<p>
						Les certifications viennent soutenir une pratique concrète : intégrer,
						exploiter, améliorer et accompagner dans la durée.
					</p>
				</div>

				<div class="timeline-line">
					<div class="timeline-step">
						<div class="timeline-dot">01</div>
						<h3>Socle sécurité</h3>
						<p>Fondamentaux cybersécurité, gouvernance, risques et SMSI.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">02</div>
						<h3>Vulnerability Management</h3>
						<p>Structuration VM, scans, remédiation, priorisation et reporting.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">03</div>
						<h3>Exposure Management</h3>
						<p>Visibilité de la surface d’attaque et contextualisation des expositions.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">04</div>
						<h3>Security Operations</h3>
						<p>Détection, investigations, automatisation et exploitation opérationnelle.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">05</div>
						<h3>Tech Champion</h3>
						<p>Reconnaissance technique et implication dans l’écosystème Rapid7.</p>
					</div>
				</div>
			</section>

			<section class="ecosystem">
				<h2>Écosystème technologique principal</h2>

				<p>
					Plateformes sur lesquelles j’interviens régulièrement en conception,
					intégration, exploitation ou amélioration continue.
				</p>

				<div class="vendors-grid">

    <div class="vendor-card">
        <img src="/Images/R7.svg" alt="Rapid7" />
        <span>Rapid7</span>
    </div>

    <div class="vendor-card">
        <img src="/Images/S1.png" alt="SentinelOne" />
        <span>SentinelOne</span>
    </div>

    <div class="vendor-card">
        <img src="/Images/RF.png" alt="Recorded Future" />
        <span>Recorded Future</span>
    </div>

    <div class="vendor-card">
        <img src="/Images/PANW.svg" alt="Palo Alto Networks" />
        <span>Palo Alto Networks</span>
    </div>

    <div class="vendor-card">
        <img src="/Images/azure.svg" alt="Microsoft Azure" />
        <span>Microsoft Azure</span>
    </div>

    <div class="vendor-card">
        <img src="/Images/nutanix.svg" alt="Nutanix" />
        <span>Nutanix</span>
    </div>

</div>
			</section>

			<section class="philosophy">
				<p>
					Une certification valide une connaissance.
					<br />
					L’expérience terrain développe l’expertise.
				</p>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.cert-hero {
		padding: 5rem;
		border-radius: 32px;
		margin-bottom: 4rem;
		color: white;
		background:
			linear-gradient(rgba(2,8,23,.82), rgba(2,8,23,.82)),
			url('/Images/fondsite.png');
		background-size: cover;
		background-position: center;
		box-shadow: 0 25px 60px rgba(2,8,23,.2);
	}

	.section-tag {
		color: #60a5fa;
		font-weight: 800;
		font-size: .85rem;
		letter-spacing: .12em;
		text-transform: uppercase;
	}

	h1 {
		font-size: 4.8rem;
		line-height: .95;
		margin: 1rem 0 2rem;
		letter-spacing: -0.05em;
		color: white;
		max-width: 900px;
	}

	.intro {
		max-width: 820px;
		font-size: 1.3rem;
		line-height: 1.8;
		color: #dbeafe;
	}

	.featured-card,
	.cert-card,
	.ecosystem {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.featured {
		margin-bottom: 4rem;
	}

	.featured-card {
		display: grid;
		grid-template-columns: 220px 1fr;
		gap: 3rem;
		align-items: center;
		padding: 3rem;
	}

	.featured-logo {
		height: 180px;
		border-radius: 24px;
		background:
			radial-gradient(circle, rgba(37,99,235,.18), transparent 55%),
			#020817;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.featured-logo img {
		width: 110px;
		height: auto;
	}

	.featured-card h2 {
		font-size: 2.7rem;
		margin: .75rem 0 1rem;
		letter-spacing: -0.04em;
	}

	.featured-card p {
		color: #475569;
		font-size: 1.1rem;
		line-height: 1.8;
		max-width: 780px;
	}

	.featured-tags,
	.badges {
		display: flex;
		flex-wrap: wrap;
		gap: .75rem;
		margin-top: 1.5rem;
	}

	.featured-tags span,
	.badges span {
		padding: .75rem 1rem;
		border-radius: 999px;
		background: #eef2ff;
		color: #2563eb;
		font-weight: 800;
		font-size: .92rem;
		border: 1px solid #dbe4ff;
	}

	.cert-section {
		margin-bottom: 4rem;
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.section-header h2,
	.ecosystem h2 {
		font-size: 3rem;
		margin: 0;
		letter-spacing: -0.04em;
	}

	.section-header p,
	.ecosystem p {
		max-width: 540px;
		color: #64748b;
		font-size: 1.1rem;
		line-height: 1.7;
		margin: 0;
	}

	.cert-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	.cert-card {
		padding: 2rem;
		text-align: center;
		min-height: 280px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		transition: all .25s ease;
	}

	.cert-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 50px rgba(15,23,42,.10);
	}

	.cert-card img {
		max-width: 120px;
		max-height: 90px;
		object-fit: contain;
		margin-bottom: 1.5rem;
	}

	.cert-card h3 {
		font-size: 1.2rem;
		margin: 0 0 .75rem;
	}

	.cert-card p {
		margin: 0;
		color: #475569;
		line-height: 1.6;
	}

	.cert-timeline {
		background:
			radial-gradient(circle at 50% 0%, rgba(37,99,235,.16), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		color: white;
		border: 1px solid rgba(96,165,250,.25);
		border-radius: 32px;
		padding: 4rem;
		box-shadow: 0 25px 60px rgba(2,8,23,.22);
		margin-bottom: 4rem;
	}

	.timeline-header {
		max-width: 780px;
		margin-bottom: 4rem;
	}

	.timeline-header h2 {
		font-size: 3rem;
		line-height: 1;
		letter-spacing: -0.04em;
		margin: 1rem 0 1.5rem;
		color: white;
	}

	.timeline-header p {
		color: #dbeafe;
		font-size: 1.15rem;
		line-height: 1.8;
	}

	.timeline-line {
		position: relative;
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 1.5rem;
	}

	.timeline-line::before {
		content: "";
		position: absolute;
		top: 31px;
		left: 8%;
		right: 8%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #2563eb, #60a5fa, #2563eb, transparent);
		box-shadow: 0 0 20px rgba(37,99,235,.8);
	}

	.timeline-step {
		position: relative;
		z-index: 1;
		text-align: center;
	}

	.timeline-dot {
		width: 64px;
		height: 64px;
		margin: 0 auto 1.5rem;
		border-radius: 999px;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(circle, rgba(96,165,250,.35), rgba(37,99,235,.16)),
			#020817;
		border: 1px solid rgba(96,165,250,.75);
		color: #93c5fd;
		font-weight: 900;
		box-shadow:
			0 0 0 8px rgba(37,99,235,.10),
			0 0 28px rgba(37,99,235,.75);
	}

	.timeline-step h3 {
		margin: 0 0 .75rem;
		color: white;
		font-size: 1.15rem;
	}

	.timeline-step p {
		margin: 0;
		color: #bfdbfe;
		font-size: .95rem;
		line-height: 1.65;
	}

	.ecosystem {
		padding: 3rem;
		margin-bottom: 4rem;
	}

	.ecosystem h2 {
		margin-bottom: 1rem;
	}

	.philosophy {
		padding: 4rem;
		border-radius: 32px;
		background:
			radial-gradient(circle at 50% 0%, rgba(37,99,235,.20), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		color: white;
		text-align: center;
		box-shadow: 0 25px 60px rgba(2,8,23,.22);
	}

	.philosophy p {
		margin: 0;
		font-size: 2.4rem;
		line-height: 1.35;
		font-weight: 900;
		letter-spacing: -0.04em;
	}

	@media (max-width: 1000px) {
		.featured-card {
			grid-template-columns: 1fr;
		}

		.cert-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.timeline-line {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.timeline-line::before {
			top: 0;
			bottom: 0;
			left: 32px;
			right: auto;
			width: 2px;
			height: auto;
			background: linear-gradient(180deg, transparent, #2563eb, #60a5fa, #2563eb, transparent);
		}

		.timeline-step {
			text-align: left;
			display: grid;
			grid-template-columns: 64px 1fr;
			column-gap: 1.25rem;
		}

		.timeline-dot {
			margin: 0;
		}

		.timeline-step h3,
		.timeline-step p {
			grid-column: 2;
		}
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 2rem, 1320px);
		}

		.cert-hero,
		.cert-timeline,
		.philosophy {
			padding: 3rem 2rem;
		}

		h1 {
			font-size: 3rem;
		}

		.section-header {
			display: block;
		}

		.cert-grid {
			grid-template-columns: 1fr;
		}

		.philosophy p {
			font-size: 1.9rem;
		}
	}

    .vendors-grid {
	display: grid;
	grid-template-columns: repeat(6, 1fr);
	gap: 1.5rem;
	margin-top: 2.5rem;
}

.vendor-card {

	background: white;

	border: 1px solid #e5e7eb;
	border-radius: 22px;

	padding: 2rem;

	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;

	text-align: center;

	transition: .25s ease;

	box-shadow: 0 10px 30px rgba(15,23,42,.04);

}

.vendor-card:hover{

	transform: translateY(-5px);

	box-shadow:
	0 18px 40px rgba(15,23,42,.10);

}

.vendor-card img{
    height:70px;
    width:auto;
    max-width:120px;
    object-fit:contain;
}

.vendor-card span{

	font-weight:700;

	color:#0f172a;

	font-size:1rem;

}

@media (max-width:1100px){

.vendors-grid{

grid-template-columns:repeat(3,1fr);

}

}

@media (max-width:700px){

.vendors-grid{

grid-template-columns:repeat(2,1fr);

}

</style>