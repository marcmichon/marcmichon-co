	}

	ul {
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		display: grid;
		gap: .75rem;
	}

	li {
		position: relative;
		padding-left: 1.8rem;
		color: #334155;
		line-height: 1.55;
	}

	li::before {
		content: "✓";
		position: absolute;
		left: 0;
		top: 0;
		color: #2563eb;
		font-weight: 900;
	}

	.negative-list li::before {
		content: "×";
		color: #0f172a;
	}

	.image-card {
		min-height: 380px;
		border-radius: 28px;
		background: url('/Images/about-workspace-secondary.png');
		background-size: cover;
		background-position: center;
		box-shadow: 0 18px 45px rgba(15,23,42,.08);
		border: 1px solid #e5e7eb;
	}

