	height: auto;
	max-height: 180px;
	object-fit: contain;
	display: block;
	transform: translateY(-1px);
}

.ack-logo-block:hover img {
	transform: translateY(-2px);
	opacity: .95;
}
	.ack-logo:hover img {
		transform: translateY(-3px);
		opacity: .95;
	}

	.two-columns,
	.content-grid,
	.three-cards {
		display: grid;
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.two-columns {
		grid-template-columns: 1fr 1fr;
	}

	.content-grid {
		grid-template-columns: 1fr 1fr 1fr;
	}

	.three-cards {
		grid-template-columns: repeat(3, 1fr);
	}

	.plain-block,
	.glass-block,
	.list-card,
	.three-cards article {
		border-radius: 28px;
		padding: 2.4rem;
		background: white;
		border: 1px solid #e5e7eb;
		box-shadow: 0 18px 45px rgba(15,23,42,.05);
	}

	.glass-block {
		background:
			radial-gradient(circle at 0% 0%, rgba(37,99,235,.10), transparent 35%),
			linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
