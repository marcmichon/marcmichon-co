---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`À propos | ${SITE_TITLE}`}
			description="À propos de Marc Michon, ingénieur cybersécurité spécialisé en Vulnerability Management, Exposure Management, Threat Intelligence et opérations de sécurité."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="about-hero">
				<div>
					<p class="section-tag">À PROPOS</p>

					<h1>Ingénieur cybersécurité</h1>

					<p class="intro">
						J’interviens sur des projets où la cybersécurité doit produire des résultats
						opérationnels mesurables : visibilité, priorisation, remédiation, détection
						et amélioration continue.
					</p>
				</div>

				<img src="/Images/moi.jpeg" alt="Marc Michon" />
			</section>

			<section class="timeline">
				<h2>Parcours</h2>

				<div class="timeline-grid">
					<div class="timeline-item">
						<span>01</span>
						<h3>Intégration</h3>
						<p>Déploiement, structuration et optimisation de plateformes cybersécurité.</p>
					</div>

					<div class="timeline-item">
						<span>02</span>
						<h3>Exploitation</h3>
						<p>MCO, RUN, support, amélioration continue et accompagnement opérationnel.</p>
					</div>

					<div class="timeline-item">
						<span>03</span>
						<h3>Expertise terrain</h3>
						<p>Vulnerability Management, Exposure Management, Threat Intelligence et SecOps.</p>
					</div>
				</div>
			</section>

			<section class="tech-stack">
				<h2>Technologies principales</h2>

				<div class="badges">
					<span>Rapid7</span>
					<span>Recorded Future</span>
					<span>SentinelOne</span>
					<span>Netskope</span>
					<span>Fortinet</span>
					<span>BeyondTrust</span>
					<span>Microsoft Security</span>
					<span>SIEM / SOAR</span>
				</div>
			</section>

			<section class="content-grid">
				<div class="main-content">
					<h2>Mon approche</h2>

					<p>
						Mon objectif est de transformer les outils de sécurité en capacités
						opérationnelles concrètes : visibilité, priorisation, remédiation,
						détection et pilotage dans la durée.
					</p>

					<p>
						Je m’intéresse particulièrement aux sujets où la technique rencontre
						l’exploitation réelle : qualité de l’inventaire, tagging, ownership,
						remédiation, automatisation, supervision et amélioration continue.
					</p>

					<h2>Domaines de travail</h2>

					<ul>
						<li>Vulnerability Management et programmes de remédiation</li>
						<li>Exposure Management et surface d’attaque</li>
						<li>Threat Intelligence et enrichissement des investigations</li>
						<li>Security Operations : SIEM, SOAR, SOC et MSSP</li>
						<li>Intégration, exploitation et amélioration continue des plateformes</li>
					</ul>
				</div>

				<aside class="side-card">
					<h3>Repères</h3>

					<div class="item">
						<strong>Rapid7</strong>
						<span>Tech Champion</span>
					</div>

					<div class="item">
						<strong>10+</strong>
						<span>années d’expérience</span>
					</div>

					<div class="item">
						<strong>VM / Exposure</strong>
						<span>spécialisation terrain</span>
					</div>

					<div class="item">
						<strong>MSSP / RUN</strong>
						<span>exploitation & services managés</span>
					</div>
				</aside>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.about-hero {
		display: grid;
		grid-template-columns: 1.35fr 0.65fr;
		align-items: center;
		gap: 4rem;
		padding: 4.5rem;
		border-radius: 32px;
		background:
			linear-gradient(rgba(2,8,23,.82), rgba(2,8,23,.82)),
			url('/Images/fondsite.png');
		background-size: cover;
		background-position: center;
		color: white;
		box-shadow: 0 25px 60px rgba(2,8,23,.2);
		margin-bottom: 3rem;
	}

	.section-tag {
		color: #60a5fa;
		font-weight: 800;
		font-size: .85rem;
		letter-spacing: .12em;
		text-transform: uppercase;
	}

	h1 {
		font-size: 4.3rem;
		line-height: .95;
		margin: 1rem 0 2rem;
		letter-spacing: -0.05em;
		color: white;
	}

	.intro {
		max-width: 820px;
		font-size: 1.25rem;
		line-height: 1.8;
		color: #dbeafe;
	}

	.about-hero img {
		width: 280px;
		height: 360px;
		object-fit: cover;
		border-radius: 28px;
		justify-self: end;
		box-shadow: 0 30px 70px rgba(0,0,0,.45);
	}

	.about-section {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		padding: 2.5rem;
		margin-bottom: 2rem;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.about-section h2 {
		font-size: 2rem;
		margin: 0 0 1.5rem;
	}

	.timeline-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.timeline-item {
		padding: 1.5rem;
		border: 1px solid #e5e7eb;
		border-radius: 18px;
		background: #f8fafc;
	}

	.timeline-item span {
		color: #2563eb;
		font-weight: 900;
		font-size: .85rem;
	}

	.timeline-item h3 {
		margin: .75rem 0;
		font-size: 1.25rem;
	}

	.timeline-item p {
		margin: 0;
		color: #475569;
		line-height: 1.6;
	}

	.badges {
		display: flex;
		flex-wrap: wrap;
		gap: .75rem;
	}

	.badges span {
		display: inline-flex;
		align-items: center;
		padding: .75rem 1rem;
		border-radius: 999px;
		background: #eef2ff;
		color: #2563eb;
		font-weight: 800;
		font-size: .95rem;
		border: 1px solid #dbe4ff;
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1fr 360px;
		gap: 3rem;
		align-items: start;
		margin-top: 2rem;
	}

	.timeline {
	margin-bottom: 3rem;
}

.tech-stack {
	margin-bottom: 3rem;
}

.content-grid {
	margin-top: 1rem;
}
	.main-content,
	.side-card {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.main-content {
		padding: 3rem;
	}

	.main-content h2 {
		font-size: 2rem;
		margin: 0 0 1.25rem;
	}

	.main-content h2:not(:first-child) {
		margin-top: 3rem;
	}

	.main-content p,
	.main-content li {
		font-size: 1.1rem;
		line-height: 1.8;
		color: #334155;
	}

	.main-content ul {
		padding-left: 1.3rem;
	}

	.side-card {
		padding: 2rem;
		position: sticky;
		top: 2rem;
	}

	.side-card h3 {
		font-size: 1.6rem;
		margin: 0 0 1.5rem;
	}

	.item {
		padding: 1.25rem 0;
		border-top: 1px solid #e5e7eb;
	}

	.item strong {
		display: block;
		font-size: 1.15rem;
		color: #0f172a;
	}

	.item span {
		display: block;
		color: #64748b;
		margin-top: .25rem;
	}

	@media (max-width: 900px) {
		main {
			width: min(100% - 2rem, 1320px);
		}

		.about-hero {
			grid-template-columns: 1fr;
			padding: 3rem 2rem;
		}

		.about-hero img {
			justify-self: start;
			width: 100%;
			height: auto;
		}

		.timeline-grid,
		.content-grid {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: 3rem;
		}
	}
</style>