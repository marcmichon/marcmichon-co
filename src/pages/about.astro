		background:
			linear-gradient(90deg, rgba(2,8,23,.94) 0%, rgba(2,8,23,.82) 42%, rgba(2,8,23,.18) 100%),
			url('/Images/fond-apropos.png');
		background-size: cover;
		background-position: center right;
		box-shadow: 0 25px 70px rgba(2,8,23,.22);
	}

