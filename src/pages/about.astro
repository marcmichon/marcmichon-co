```astro
---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const foundItems = [
	'Des Notes de terrain issues d’expériences concrètes',
	'Des schémas pour expliquer des concepts complexes',
	'Des checklists opérationnelles et réutilisables',
	'Des méthodes de travail applicables sur le terrain',
	'Des réflexions sur la gouvernance, le risque et la remédiation',
	'Des principes applicables indépendamment des technologies utilisées',
];

const notFoundItems = [
	'Des copier-coller de documentations',
	'Des comparatifs marketing',
	'Des articles écrits uniquement pour le SEO',
	'Des classements de produits',
	'Des solutions présentées comme universelles',
];

const explorations = [
	'Exposure Management',
	'Risk Based Prioritization',
	'Attack Surface',
	'AI appliquée à la cybersécurité',
	'Gouvernance VM',
];

const principles = [
	{
		title: 'Le terrain avant la théorie.',
		text: 'Les concepts prennent tout leur sens lorsqu’ils sont confrontés à des situations réelles.',
	},
	{
		title: 'Comprendre avant d’optimiser.',
		text: 'Un problème bien compris est souvent déjà à moitié résolu.',
	},
	{
		title: 'Expliquer avant de recommander.',
		text: 'Une recommandation a plus de valeur lorsqu’on comprend le raisonnement qui la justifie.',
	},
	{
		title: 'Partager avant de convaincre.',
		text: 'L’objectif n’est pas d’avoir raison. L’objectif est d’alimenter la réflexion.',
	},
];
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`À propos | ${SITE_TITLE}`}
			description="Pourquoi marcmichon.co existe : partager des retours d'expérience, méthodes et principes de cybersécurité issus du terrain."
		/>
	</head>

	<body>
		<Header />

		<main>
		<section class="hero">
	<div class="hero-content">
		<p class="eyebrow">À PROPOS</p>

		<h1>Partager ce que le terrain m’a appris.</h1>

		<span class="hero-line"></span>

		<p class="hero-company">
	Je suis ingénieur réseaux et sécurité chez
	<a
		href="https://www.acknowledge.fr"
		target="_blank"
		rel="noopener noreferrer"
		class="ack-logo"
		aria-label="ACKnowledge"
	>
		<img src="/Images/ACKnowledge-logo-transparent.png" alt="ACKnowledge" />
	</a>,
	où j’accompagne des organisations dans la conception, le déploiement
	et l’exploitation de solutions de cybersécurité.
</p>
	

		<p>
			J’ai créé <strong>marcmichon.co</strong> pour partager des méthodes,
			des retours d’expérience et des principes issus du terrain,
			qui dépassent les outils et restent utiles quelle que soit la technologie utilisée.
		</p>
	</div>
</section>

			<section class="two-columns">
				<article class="plain-block">
					<div class="icon">◎</div>
					<h2>Pourquoi ce site existe</h2>
					<p>
						Les difficultés rencontrées sont rarement liées uniquement aux outils.
						Les technologies évoluent rapidement. Les interfaces changent. Les fonctionnalités
						apparaissent.
					</p>
					<p>
						Les concepts, eux, restent : comprendre son patrimoine, prioriser le risque,
						structurer une gouvernance, faire collaborer les équipes et transformer des
						données techniques en décisions opérationnelles.
					</p>
					<p>
						C’est précisément sur ces sujets que se joue la réussite d’un programme de
						cybersécurité. Et pourtant, ce sont souvent les moins documentés.
					</p>
					<strong>C’est pour cette raison que ce site existe.</strong>
				</article>

				<article class="glass-block">
					<div class="icon">✎</div>
					<h2>Pourquoi des Notes de terrain ?</h2>
					<p>
						La plupart des documentations expliquent comment utiliser un produit.
						Les Notes de terrain cherchent à répondre à une autre question :
					</p>
					<blockquote>Comment réussir un programme&nbsp;?</blockquote>
					<p>
						Les meilleures idées que j’ai retenues ne venaient pas d’une documentation.
						Elles venaient d’une mission, d’une architecture à simplifier, d’un programme à
						reconstruire, d’une erreur à comprendre ou d’une décision à prendre avec peu
						d’informations.
					</p>
					<p>
						Chaque Note publiée ici est inspirée de situations réelles, sans jamais divulguer
						d’informations confidentielles concernant les organisations accompagnées.
					</p>
				</article>
			</section>

			<section class="quote-band">
				<div class="quote-mark">“</div>
				<p>
					La technologie change vite.<br />
					Les bons principes vieillissent beaucoup plus lentement.
				</p>
			</section>

			<section class="content-grid">
				<article class="list-card">
					<div class="icon">⌖</div>
					<h2>Ce que vous trouverez ici</h2>
					<ul>
						{foundItems.map((item) => <li>{item}</li>)}
					</ul>
					<strong>
						L’objectif n’est pas de fournir des recettes universelles. L’objectif est
						d’aider à prendre de meilleures décisions.
					</strong>
				</article>

				<article class="list-card">
					<div class="icon">×</div>
					<h2>Ce que vous ne trouverez pas ici</h2>
					<ul class="negative-list">
						{notFoundItems.map((item) => <li>{item}</li>)}
					</ul>
					<p>
						Chaque organisation possède son contexte, ses contraintes et sa maturité.
						Les Notes de terrain proposent des principes, pas des vérités absolues.
					</p>
				</article>

				<div class="image-card secondary-image" aria-label="Espace de travail cybersécurité"></div>
			</section>

			<section class="three-cards">
				<article>
					<div class="icon">♙</div>
					<h2>Pourquoi j’écris</h2>
					<p>
						J’aurais pu garder ces notes pour moi. Les utiliser uniquement dans mes missions.
						Les laisser dans un carnet ou sur un disque dur.
					</p>
					<strong>J’ai préféré les partager.</strong>
					<p>
						Parce que je suis convaincu qu’une idée utile n’a de valeur que lorsqu’elle
						circule. Parce que la cybersécurité est un sport d’équipe.
					</p>
				</article>

				<article>
					<div class="icon">▧</div>
					<h2>Ce que j’explore en ce moment</h2>
					<p>
						Les sujets évoluent. Les menaces évoluent. Les organisations évoluent.
					</p>
					<div class="tags">
						{explorations.map((item) => <span>{item}</span>)}
					</div>
					<p>
						Ces explorations nourriront les prochaines Notes de terrain.
					</p>
				</article>

				<article>
					<div class="icon">▣</div>
					<h2>Ce que le terrain m’a appris</h2>

					<p>
						Au fil des missions menées chez
						<a
							href="https://www.acknowledge.fr"
							target="_blank"
							rel="noopener noreferrer"
						>
							ACKnowledge
						</a>,
						j’ai travaillé sur des sujets tels que le Vulnerability Management,
						l’Endpoint Protection, le PAM, la segmentation réseau,
						la détection et la réponse aux incidents.
					</p>

					<p>
						Au-delà des technologies, les mêmes questions reviennent régulièrement :
						comment prioriser, comment gouverner, comment mesurer la réduction du risque
						et comment construire un programme durable.
					</p>

					<p>
						C’est cette expérience opérationnelle, anonymisée et reformulée sous forme
						de principes, que j’essaie de partager dans les Notes de terrain.
					</p>
				</article>
			</section>

			<section class="principles">
				<div class="section-heading">
					<h2>Les principes qui guident ce site</h2>
					<span></span>
				</div>

				<div class="principles-grid">
					{principles.map((principle) => (
						<article>
							<div class="principle-icon">◎</div>
							<h3>{principle.title}</h3>
							<p>{principle.text}</p>
						</article>
					))}
				</div>
			</section>

			<section class="cta">
				<div class="cta-icon">➤</div>
				<div>
					<h2>Et maintenant&nbsp;?</h2>
					<p>
						Si un article vous fait réfléchir, si une idée vous semble incomplète ou si
						votre expérience est différente, alors discutons-en. Les meilleures Notes de
						terrain naissent souvent d’une conversation.
					</p>
				</div>
				<a href="/contact">Me contacter →</a>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
		color: #0f172a;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.hero {
		min-height: 520px;
		border-radius: 34px;
