	}

	.section-heading span {
		display: inline-block;
		width: 60px;
		height: 4px;
		border-radius: 999px;
		background: #2563eb;
	}

	.principles-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	.principles-grid article {
		text-align: center;
		padding: 1.8rem;
		border-right: 1px solid #e5e7eb;
	}

	.principles-grid article:last-child {
		border-right: none;
	}

	.principle-icon {
		margin: 0 auto 1rem;
		color: #2563eb;
		font-size: 2rem;
		font-weight: 900;
	}

	.principles-grid h3 {
		margin: 0 0 .6rem;
		color: #0f172a;
		font-size: 1.05rem;
	}

	.principles-grid p {
