---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`À propos | ${SITE_TITLE}`}
			description="À propos de Marc Michon, ingénieur cybersécurité spécialisé en intégration, exploitation, Vulnerability Management, Exposure Management et opérations de sécurité."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="about-hero">
				<div class="hero-text">
					<p class="section-tag">À PROPOS</p>

					<h1>Ingénieur cybersécurité terrain</h1>

					<p class="intro">
						J’interviens sur des projets où la cybersécurité doit produire des résultats
						opérationnels mesurables : visibilité, priorisation, remédiation, détection
						et amélioration continue.
					</p>
				</div>

				<div class="hero-photo">
					<img src="/Images/moi.jpeg" alt="Marc Michon" />
				</div>
			</section>

			<section class="identity-card">
				<div>
					<p class="section-tag">POSITIONNEMENT</p>
					<h2>Transformer les outils en capacités opérationnelles</h2>
					<p>
						Mon approche consiste à relier la technique, les processus et l’exploitation :
						structurer les plateformes, fiabiliser la donnée, prioriser les actions et
						accompagner leur usage dans la durée.
					</p>
				</div>

				<div class="identity-stats">
					<div>
						<strong>10+</strong>
						<span>années d’expérience</span>
					</div>

					<div>
						<strong>Rapid7</strong>
						<span>Tech Champion</span>
					</div>

					<div>
						<strong>VM / Exposure</strong>
						<span>spécialisation terrain</span>
					</div>

					<div>
						<strong>MSSP / RUN</strong>
						<span>exploitation opérationnelle</span>
					</div>
				</div>
			</section>

			<section class="journey">
				<div class="journey-header">
					<p class="section-tag">PARCOURS</p>
					<h2>Une trajectoire orientée intégration et exploitation</h2>
					<p>
						Un parcours construit autour de la mise en œuvre concrète des plateformes
						de cybersécurité, de leur exploitation et de leur amélioration continue.
					</p>
				</div>

				<div class="timeline-line">
					<div class="timeline-step">
						<div class="timeline-dot">01</div>
						<h3>Intégration</h3>
						<p>Déploiement, structuration, configuration et optimisation de plateformes cybersécurité.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">02</div>
						<h3>Exploitation</h3>
						<p>MCO, RUN, support, supervision, tuning et accompagnement opérationnel.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">03</div>
						<h3>Expertise terrain</h3>
						<p>Vulnerability Management, Exposure Management, Threat Intelligence et SecOps.</p>
					</div>

					<div class="timeline-step">
						<div class="timeline-dot">04</div>
						<h3>Amélioration</h3>
						<p>Automatisation, reporting, industrialisation et amélioration continue.</p>
					</div>
				</div>
			</section>

			<section class="approach-grid">
				<div class="approach-card">
					<h2>Mon approche</h2>

					<ul>
						<li>Comprendre le contexte et les contraintes opérationnelles.</li>
						<li>Structurer les plateformes pour produire une donnée exploitable.</li>
						<li>Prioriser les actions selon le risque et le contexte métier.</li>
						<li>Faire vivre les solutions dans la durée : RUN, tuning, reporting.</li>
					</ul>
				</div>

				<div class="approach-card">
					<h2>Ce que j’apporte</h2>

					<ul>
						<li>Une vision terrain, pragmatique et orientée exploitation.</li>
						<li>Une capacité à relier architecture, intégration et opérations.</li>
						<li>Une spécialisation forte sur VM, Exposure Management et SecOps.</li>
						<li>Une logique d’amélioration continue, sans surcomplexifier.</li>
					</ul>
				</div>
			</section>

			<section class="ecosystem">
				<h2>Écosystème technologique principal</h2>

				<p>
					Plateformes sur lesquelles j’interviens régulièrement en conception,
					intégration, exploitation ou amélioration continue.
				</p>

				<div class="vendors-grid">
					<div class="vendor-card">
						<img src="/Images/R7.svg" alt="Rapid7" />
						<span>Rapid7</span>
					</div>

					<div class="vendor-card">
						<img src="/Images/S1.png" alt="SentinelOne" />
						<span>SentinelOne</span>
					</div>

					<div class="vendor-card">
						<img src="/Images/RF.png" alt="Recorded Future" />
						<span>Recorded<br />Future</span>
					</div>

					<div class="vendor-card">
						<img src="/Images/PANW.svg" alt="Palo Alto Networks" />
						<span>Palo Alto<br />Networks</span>
					</div>

					<div class="vendor-card">
						<img src="/Images/azure.svg" alt="Microsoft Azure" />
						<span>Microsoft<br />Azure</span>
					</div>

					<div class="vendor-card">
						<img src="/Images/nutanix.svg" alt="Nutanix" />
						<span>Nutanix</span>
					</div>
				</div>
			</section>

			<section class="final-note">
				<p>
					Transformer une plateforme de cybersécurité en capacité opérationnelle durable.
				</p>

				<span>Architecture • Intégration • Exploitation • Amélioration continue</span>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.about-hero {
		display: grid;
		grid-template-columns: 1.35fr 0.65fr;
		align-items: center;
		gap: 4rem;
		padding: 4.5rem;
		border-radius: 32px;
		background:
			linear-gradient(rgba(2,8,23,.82), rgba(2,8,23,.82)),
			url('/Images/fondsite.png');
		background-size: cover;
		background-position: center;
		color: white;
		box-shadow: 0 25px 60px rgba(2,8,23,.2);
		margin-bottom: 4rem;
	}

	.section-tag {
		color: #60a5fa;
		font-weight: 800;
		font-size: .85rem;
		letter-spacing: .12em;
		text-transform: uppercase;
	}

	h1 {
		font-size: 4.4rem;
		line-height: .95;
		margin: 1rem 0 2rem;
		letter-spacing: -0.05em;
		color: white;
	}

	.intro {
		max-width: 820px;
		font-size: 1.25rem;
		line-height: 1.8;
		color: #dbeafe;
	}

	.hero-photo img {
		width: 280px;
		height: 360px;
		object-fit: cover;
		border-radius: 28px;
		justify-self: end;
		box-shadow: 0 30px 70px rgba(0,0,0,.45);
	}

	.identity-card,
	.approach-card,
	.ecosystem {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.identity-card {
		display: grid;
		grid-template-columns: 1.2fr .8fr;
		gap: 3rem;
		align-items: center;
		padding: 3rem;
		margin-bottom: 4rem;
	}

	.identity-card h2,
	.approach-card h2,
	.ecosystem h2 {
		font-size: 2.4rem;
		line-height: 1.05;
		margin: .75rem 0 1rem;
		letter-spacing: -0.04em;
	}

	.identity-card p,
	.ecosystem p {
		color: #475569;
		font-size: 1.1rem;
		line-height: 1.8;
		max-width: 780px;
	}

	.identity-stats {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
	}

	.identity-stats div {
		border: 1px solid #e5e7eb;
		border-radius: 18px;
		padding: 1.5rem;
		background: #f8fafc;
	}

	.identity-stats strong {
		display: block;
		font-size: 1.4rem;
		color: #0f172a;
	}

	.identity-stats span {
		display: block;
		color: #64748b;
		margin-top: .4rem;
		line-height: 1.4;
	}

	.journey {
		background:
			radial-gradient(circle at 50% 0%, rgba(37,99,235,.16), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		color: white;
		border: 1px solid rgba(96,165,250,.25);
		border-radius: 32px;
		padding: 4rem;
		box-shadow: 0 25px 60px rgba(2,8,23,.22);
		margin-bottom: 4rem;
	}

	.journey-header {
		max-width: 820px;
		margin-bottom: 4rem;
	}

	.journey-header h2 {
		font-size: 3rem;
		line-height: 1;
		letter-spacing: -0.04em;
		margin: 1rem 0 1.5rem;
		color: white;
	}

	.journey-header p {
		color: #dbeafe;
		font-size: 1.15rem;
		line-height: 1.8;
	}

	.timeline-line {
		position: relative;
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.5rem;
	}

	.timeline-line::before {
		content: "";
		position: absolute;
		top: 31px;
		left: 10%;
		right: 10%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #2563eb, #60a5fa, #2563eb, transparent);
		box-shadow: 0 0 20px rgba(37,99,235,.8);
	}

	.timeline-step {
		position: relative;
		z-index: 1;
		text-align: center;
	}

	.timeline-dot {
		width: 64px;
		height: 64px;
		margin: 0 auto 1.5rem;
		border-radius: 999px;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(circle, rgba(96,165,250,.35), rgba(37,99,235,.16)),
			#020817;
		border: 1px solid rgba(96,165,250,.75);
		color: #93c5fd;
		font-weight: 900;
		box-shadow:
			0 0 0 8px rgba(37,99,235,.10),
			0 0 28px rgba(37,99,235,.75);
	}

	.timeline-step h3 {
		margin: 0 0 .75rem;
		color: white;
		font-size: 1.2rem;
	}

	.timeline-step p {
		margin: 0;
		color: #bfdbfe;
		font-size: .95rem;
		line-height: 1.65;
	}

	.approach-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
		margin-bottom: 4rem;
	}

	.approach-card {
		padding: 3rem;
	}

	.approach-card ul {
		margin: 1.5rem 0 0;
		padding-left: 1.2rem;
	}

	.approach-card li {
		color: #334155;
		font-size: 1.05rem;
		line-height: 1.8;
		margin-bottom: .5rem;
	}

	.ecosystem {
		padding: 3rem;
		margin-bottom: 4rem;
	}

	.vendors-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1.25rem;
		margin-top: 2.5rem;
	}

	.vendor-card {
		border: 1px solid #e5e7eb;
		border-radius: 20px;
		padding: 2rem 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		background: white;
		box-shadow: 0 10px 25px rgba(15,23,42,.04);
		transition: all .25s ease;
		min-height: 150px;
	}

	.vendor-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 50px rgba(15,23,42,.10);
	}

	.vendor-card img {
		height: 64px;
		max-width: 110px;
		object-fit: contain;
		margin-bottom: 1rem;
		transition: .25s ease;
	}

	.vendor-card:hover img {
		transform: scale(1.06);
	}

	.vendor-card span {
		font-weight: 800;
		color: #0f172a;
		line-height: 1.35;
	}

	.final-note {
		background:
			radial-gradient(circle at 50% 0%, rgba(37,99,235,.20), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		color: white;
		padding: 4rem;
		border-radius: 32px;
		box-shadow: 0 25px 60px rgba(2,8,23,.22);
		text-align: center;
	}

	.final-note p {
		margin: 0 auto 1rem;
		max-width: 900px;
		font-size: 2.4rem;
		line-height: 1.25;
		font-weight: 900;
		letter-spacing: -0.04em;
	}

	.final-note span {
		color: #93c5fd;
		font-weight: 800;
	}

	@media (max-width: 1000px) {
		.about-hero,
		.identity-card,
		.approach-grid {
			grid-template-columns: 1fr;
		}

		.hero-photo img {
			width: 100%;
			height: auto;
		}

		.vendors-grid {
			grid-template-columns: repeat(3, 1fr);
		}

		.timeline-line {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.timeline-line::before {
			top: 0;
			bottom: 0;
			left: 32px;
			right: auto;
			width: 2px;
			height: auto;
			background: linear-gradient(180deg, transparent, #2563eb, #60a5fa, #2563eb, transparent);
		}

		.timeline-step {
			text-align: left;
			display: grid;
			grid-template-columns: 64px 1fr;
			column-gap: 1.25rem;
		}

		.timeline-dot {
			margin: 0;
		}

		.timeline-step h3,
		.timeline-step p {
			grid-column: 2;
		}
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 2rem, 1320px);
		}

		.about-hero,
		.journey,
		.final-note {
			padding: 3rem 2rem;
		}

		h1 {
			font-size: 3rem;
		}

		.journey-header h2,
		.identity-card h2,
		.approach-card h2,
		.ecosystem h2 {
			font-size: 2.2rem;
		}

		.identity-stats,
		.vendors-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.final-note p {
			font-size: 1.9rem;
		}
	}
</style>