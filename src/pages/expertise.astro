---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`Expertise | ${SITE_TITLE}`}
			description="Expertises cybersécurité autour du Vulnerability Management, Exposure Management, Threat Intelligence, Security Operations et MSSP / RUN."
		/>
	</head>

	<body>
		<Header />

		<main>
	<section class="expertise-hero">
	<div class="hero-content">
		<p class="section-tag">EXPERTISE</p>

		<h1>Ingénierie cybersécurité opérationnelle</h1>

		<span class="hero-line"></span>

		<p class="hero-company">
			Cette expertise s’est construite au travers de nombreuses missions
			réalisées chez

			<a
				href="https://www.acknowledge.fr"
				target="_blank"
				rel="noopener noreferrer"
				class="ack-logo"
				aria-label="ACKnowledge"
			>
				<img
					src="/Images/ACKnowledge-logo-transparent.png"
					alt="ACKnowledge"
				/>
			</a>,

			auprès d’organisations de tailles et de secteurs variés.
		</p>

		<p>
			Elle est le fruit d’expériences concrètes, de projets d’intégration,
			d’audits, de résolution d’incidents et d’accompagnement des équipes
			sécurité dans leur quotidien.
		</p>
	</div>
</section>

			<section class="domains">
				<div class="section-header">
					<h2>5 domaines d’expertise</h2>
					<p>Une approche terrain, orientée visibilité, priorisation, exploitation et amélioration continue.</p>
				</div>

				<div class="expertise-grid">
					<article class="expertise-card">
						<img src="/Images/vulnmngt.png" alt="" />
						<div>
							<h3>Vulnerability Management</h3>
							<p>Structuration de programmes VM : inventaire, tagging, priorisation, remédiation et reporting.</p>
							<ul>
								<li>Visibilité assets</li>
								<li>Priorisation du risque</li>
								<li>Programmes de remédiation</li>
							</ul>
						</div>
					</article>

					<article class="expertise-card">
						<img src="/Images/exposurmngt.png" alt="" />
						<div>
							<h3>Exposure Management</h3>
							<p>Réduction de la surface d’attaque grâce à une meilleure contextualisation des expositions.</p>
							<ul>
								<li>Surface d’attaque</li>
								<li>Contexte de risque</li>
								<li>Exposition externe</li>
							</ul>
						</div>
					</article>

					<article class="expertise-card">
						<img src="/Images/cti.png" alt="" />
						<div>
							<h3>Threat Intelligence</h3>
							<p>Enrichissement des investigations avec des indicateurs, du contexte menace et des sources TI.</p>
							<ul>
								<li>IOC & enrichissement</li>
								<li>Contexte menace</li>
								<li>Intégration SIEM / SOAR</li>
							</ul>
						</div>
					</article>

					<article class="expertise-card">
						<img src="/Images/secops.png" alt="" />
						<div>
							<h3>Security Operations</h3>
							<p>Détection, exploitation SIEM / SOAR, qualification des alertes et amélioration des opérations SOC.</p>
							<ul>
								<li>SIEM / SOAR</li>
								<li>Détection & alerting</li>
								<li>Automatisation</li>
							</ul>
						</div>
					</article>

					<article class="expertise-card wide">
						<img src="/Images/mssp.png" alt="" />
						<div>
							<h3>MSSP / RUN</h3>
							<p>Maintien en condition opérationnelle, support client, optimisation continue et pilotage de plateformes sécurité.</p>
							<ul>
								<li>MCO / RUN</li>
								<li>Support opérationnel</li>
								<li>Amélioration continue</li>
							</ul>
						</div>
					</article>
				</div>
			</section>

			<section class="methodology">
	<div class="methodology-header">
		<p class="section-tag">MÉTHODOLOGIE</p>
		<h2>Une approche terrain, de bout en bout</h2>
		<p>
			De la compréhension du contexte à l’amélioration continue, l’objectif est de transformer
			les plateformes de cybersécurité en capacités réellement exploitables.
		</p>
	</div>

	<div class="timeline-line">
		<div class="timeline-step">
			<div class="timeline-dot">01</div>
			<h3>Comprendre</h3>
			<p>Contexte métier, périmètre, objectifs, contraintes et priorités opérationnelles.</p>
		</div>

		<div class="timeline-step">
			<div class="timeline-dot">02</div>
			<h3>Concevoir</h3>
			<p>Architecture, modèle d’exploitation, processus, tagging et gouvernance.</p>
		</div>

		<div class="timeline-step">
			<div class="timeline-dot">03</div>
			<h3>Intégrer</h3>
			<p>Déploiement, configuration, connecteurs, automatisation et industrialisation.</p>
		</div>

		<div class="timeline-step">
			<div class="timeline-dot">04</div>
			<h3>Exploiter</h3>
			<p>RUN, supervision, support, qualification, reporting et amélioration opérationnelle.</p>
		</div>

		<div class="timeline-step">
			<div class="timeline-dot">05</div>
			<h3>Améliorer</h3>
			<p>Mesure, tuning, optimisation, automatisation et amélioration continue.</p>
		</div>
	</div>
</section>
		</main>

		<Footer />
	</body>
</html>

```css
<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1320px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	/* ==========================
	   HERO
	========================== */

	.hero-company {
	margin: 0 0 1rem;
	color: #dbeafe;
	font-size: 1.25rem;
	line-height: 1.75;
}

.ack-logo {
	display: inline-flex;
	align-items: center;
	vertical-align: middle;
	margin: 0 .25rem;
	text-decoration: none;
}

.ack-logo img {
	height: 42px;
	width: auto;
	display: block;
	transform: translateY(-1px);
}

.ack-logo:hover img {
	opacity: .9;
}
	.expertise-hero {
		min-height: 520px;
		border-radius: 34px;
		margin-bottom: 5rem;
		overflow: hidden;
		display: flex;
		align-items: center;
		background:
			linear-gradient(90deg, rgba(2,8,23,.94) 0%, rgba(2,8,23,.82) 42%, rgba(2,8,23,.18) 100%),
			url('/Images/fondsite.png');
		background-size: cover;
		background-position: center right;
		box-shadow: 0 25px 70px rgba(2,8,23,.22);
	}

	.hero-content {
		max-width: 760px;
		padding: 4.5rem;
		color: white;
	}

	.section-tag {
		color: #60a5fa;
		font-weight: 800;
		font-size: .85rem;
		letter-spacing: .12em;
		text-transform: uppercase;
		margin: 0;
	}

	h1 {
		font-size: 4.8rem;
		line-height: .95;
		margin: 1rem 0 0;
		letter-spacing: -0.05em;
		color: white;
		max-width: 900px;
	}

	.hero-line {
		display: block;
		width: 56px;
		height: 4px;
		border-radius: 999px;
		background: #2563eb;
		margin: 2rem 0;
	}

	.expertise-hero p:not(.section-tag) {
		margin: 0 0 1rem;
		color: #dbeafe;
		font-size: 1.25rem;
		line-height: 1.75;
	}

	.expertise-hero p:last-child {
		margin-bottom: 0;
	}

	.expertise-hero a {
		color: white;
		font-weight: 900;
		text-decoration: none;
	}

	.expertise-hero a:hover {
		text-decoration: underline;
	}

	/* ==========================
	   DOMAINS
	========================== */

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	.section-header h2,
	.methodology h2 {
		font-size: 3rem;
		margin: 0;
		letter-spacing: -0.04em;
	}

	.section-header p {
		max-width: 520px;
		color: #64748b;
		font-size: 1.1rem;
		line-height: 1.7;
		margin: 0;
	}

	.expertise-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2rem;
		margin-bottom: 5rem;
	}

	.expertise-card {
		display: grid;
		grid-template-columns: 230px 1fr;
		gap: 1.75rem;
		align-items: stretch;
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
		transition: all .25s ease;
	}

	.expertise-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 20px 50px rgba(15,23,42,.10);
	}

	.expertise-card img {
		width: 100%;
		height: 100%;
		min-height: 280px;
		object-fit: cover;
		display: block;
	}

	.expertise-card div {
		padding: 2rem 2rem 2rem 0;
	}

	.expertise-card h3 {
		font-size: 1.7rem;
		line-height: 1.15;
		margin: 0 0 1rem;
	}

	.expertise-card p {
		color: #475569;
		line-height: 1.7;
		margin: 0 0 1rem;
	}

	.expertise-card ul {
		margin: 0;
		padding-left: 1.2rem;
		color: #334155;
		line-height: 1.8;
	}

	.expertise-card.wide {
		grid-column: span 2;
	}

	/* ==========================
	   METHODOLOGY TIMELINE
	========================== */

	.methodology {
		background:
			radial-gradient(circle at 50% 0%, rgba(37, 99, 235, 0.16), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		color: white;
		border: 1px solid rgba(96, 165, 250, 0.25);
		border-radius: 32px;
		padding: 4rem;
		box-shadow: 0 25px 60px rgba(2, 8, 23, 0.22);
		overflow: hidden;
	}

	.methodology-header {
		max-width: 760px;
		margin-bottom: 4rem;
	}

	.methodology-header h2 {
		font-size: 3rem;
		line-height: 1;
		letter-spacing: -0.04em;
		margin: 1rem 0 1.5rem;
		color: white;
	}

	.methodology-header p {
		color: #dbeafe;
		font-size: 1.15rem;
		line-height: 1.8;
		margin: 0;
	}

	.timeline-line {
		position: relative;
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 1.5rem;
	}

	.timeline-line::before {
		content: "";
		position: absolute;
		top: 31px;
		left: 8%;
		right: 8%;
		height: 2px;
		background: linear-gradient(90deg, transparent, #2563eb, #60a5fa, #2563eb, transparent);
		box-shadow: 0 0 20px rgba(37, 99, 235, 0.8);
		z-index: 0;
	}

	.timeline-step {
		position: relative;
		z-index: 1;
		text-align: center;
	}

	.timeline-dot {
		width: 64px;
		height: 64px;
		margin: 0 auto 1.5rem;
		border-radius: 999px;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			radial-gradient(circle, rgba(96, 165, 250, 0.35), rgba(37, 99, 235, 0.16)),
			#020817;
		border: 1px solid rgba(96, 165, 250, 0.75);
		color: #93c5fd;
		font-weight: 900;
		font-size: 0.95rem;
		box-shadow:
			0 0 0 8px rgba(37, 99, 235, 0.10),
			0 0 28px rgba(37, 99, 235, 0.75);
	}

	.timeline-step h3 {
		margin: 0 0 0.75rem;
		font-size: 1.2rem;
		color: white;
	}

	.timeline-step p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.65;
		color: #bfdbfe;
	}

	/* ==========================
	   RESPONSIVE
	========================== */

	@media (max-width: 1000px) {
		.expertise-grid,
		.expertise-card,
		.expertise-card.wide {
			display: block;
			grid-column: auto;
		}

		.expertise-card img {
			height: 220px;
			min-height: auto;
		}

		.expertise-card div {
			padding: 2rem;
		}

		.timeline-line {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.timeline-line::before {
			top: 0;
			bottom: 0;
			left: 32px;
			right: auto;
			width: 2px;
			height: auto;
			background: linear-gradient(180deg, transparent, #2563eb, #60a5fa, #2563eb, transparent);
		}

		.timeline-step {
			text-align: left;
			display: grid;
			grid-template-columns: 64px 1fr;
			column-gap: 1.25rem;
			align-items: start;
		}

		.timeline-dot {
			margin: 0;
		}

		.timeline-step h3,
		.timeline-step p {
			grid-column: 2;
		}
	}

	@media (max-width: 640px) {
		main {
			width: min(100% - 2rem, 1320px);
		}

		.expertise-hero {
			min-height: auto;
			background:
				linear-gradient(rgba(2,8,23,.86), rgba(2,8,23,.86)),
				url('/Images/fondsite.png');
			background-size: cover;
			background-position: center;
		}

		.hero-content {
			padding: 3rem 2rem;
		}

		h1 {
			font-size: 3rem;
		}

		.expertise-hero p:not(.section-tag) {
			font-size: 1.1rem;
		}

		.section-header {
			display: block;
		}

		.section-header h2,
		.methodology h2 {
			font-size: 2.4rem;
		}

		.expertise-grid {
			grid-template-columns: 1fr;
		}

		.methodology {
			padding: 3rem 2rem;
		}

		.methodology-header h2 {
			font-size: 2.4rem;
		}
	}
</style>
```
