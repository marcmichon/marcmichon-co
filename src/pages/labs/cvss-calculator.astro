---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---


<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`CVSS Calculator | ${SITE_TITLE}`}
			description="Un calculateur pédagogique CVSS v4.0 pour construire, comprendre et expliquer un vecteur de sévérité."
		/>
	</head>

	<body>
		<Header />

		<main>
			<section class="hero">
				<p class="tag">VULNERABILITY MANAGEMENT</p>

				<h1>CVSS Calculator</h1>

				<p class="hero-intro">
					Construisez un vecteur CVSS v4.0 et comprenez immédiatement
					les éléments qui influencent la sévérité technique d’une vulnérabilité.
				</p>

			<div class="method-disclaimer">
	<strong>Implémentation CVSS v4.0 officielle</strong>

	<p>
		Le score est calculé à partir de l’implémentation de référence
		publiée par FIRST sous licence BSD-2-Clause. CVSS est détenu et
		maintenu par FIRST.Org, Inc. Le score et son vecteur sont toujours
		affichés ensemble conformément aux recommandations de la
		spécification CVSS v4.0.
	</p>
</div>
			</section>

			<div class="calculator-layout">
				<form class="cvss-form" id="cvss-form">
					<section class="metric-section">
						<div class="section-number">1</div>

						<div class="section-content">
							<div class="section-heading">
								<p>Exploitabilité</p>
								<h2>Comment l’attaque peut-elle être réalisée ?</h2>
							</div>

							<div class="metrics-grid">
								<fieldset class="metric-card">
									<legend>Vecteur d’attaque</legend>
									<p class="metric-code">AV</p>

									<div class="choices">
										<label>
											<input
												type="radio"
												name="AV"
												value="N"
												data-label="Réseau"
												checked
											/>
											<span>
												<strong>Réseau</strong>
												<small>Exploitation distante</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="AV"
												value="A"
												data-label="Adjacent"
											/>
											<span>
												<strong>Adjacent</strong>
												<small>Réseau local ou proximité logique</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="AV"
												value="L"
												data-label="Local"
											/>
											<span>
												<strong>Local</strong>
												<small>Accès local nécessaire</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="AV"
												value="P"
												data-label="Physique"
											/>
											<span>
												<strong>Physique</strong>
												<small>Manipulation directe</small>
											</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="metric-card">
									<legend>Complexité de l’attaque</legend>
									<p class="metric-code">AC</p>

									<div class="choices two">
										<label>
											<input
												type="radio"
												name="AC"
												value="L"
												data-label="Faible"
												checked
											/>
											<span>
												<strong>Faible</strong>
												<small>Peu de contraintes techniques</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="AC"
												value="H"
												data-label="Élevée"
											/>
											<span>
												<strong>Élevée</strong>
												<small>Conditions complexes</small>
											</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="metric-card">
									<legend>Conditions d’attaque</legend>
									<p class="metric-code">AT</p>

									<div class="choices two">
										<label>
											<input
												type="radio"
												name="AT"
												value="N"
												data-label="Aucune"
												checked
											/>
											<span>
												<strong>Aucune</strong>
												<small>Pas de condition particulière</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="AT"
												value="P"
												data-label="Présentes"
											/>
											<span>
												<strong>Présentes</strong>
												<small>État spécifique requis</small>
											</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="metric-card">
									<legend>Privilèges requis</legend>
									<p class="metric-code">PR</p>

									<div class="choices three">
										<label>
											<input
												type="radio"
												name="PR"
												value="N"
												data-label="Aucun"
												checked
											/>
											<span>
												<strong>Aucun</strong>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="PR"
												value="L"
												data-label="Faibles"
											/>
											<span>
												<strong>Faibles</strong>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="PR"
												value="H"
												data-label="Élevés"
											/>
											<span>
												<strong>Élevés</strong>
											</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="metric-card full">
									<legend>Interaction utilisateur</legend>
									<p class="metric-code">UI</p>

									<div class="choices three">
										<label>
											<input
												type="radio"
												name="UI"
												value="N"
												data-label="Aucune"
												checked
											/>
											<span>
												<strong>Aucune</strong>
												<small>Exploitation autonome</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="UI"
												value="P"
												data-label="Passive"
											/>
											<span>
												<strong>Passive</strong>
												<small>Action indirecte de la victime</small>
											</span>
										</label>

										<label>
											<input
												type="radio"
												name="UI"
												value="A"
												data-label="Active"
											/>
											<span>
												<strong>Active</strong>
												<small>Action volontaire nécessaire</small>
											</span>
										</label>
									</div>
								</fieldset>
							</div>
						</div>
					</section>

					<section class="metric-section">
						<div class="section-number">2</div>

						<div class="section-content">
							<div class="section-heading">
								<p>Système vulnérable</p>
								<h2>Quel est l’impact direct sur la cible ?</h2>
							</div>

							<div class="impact-grid">
								<fieldset class="impact-card">
									<legend>Confidentialité</legend>
									<p class="metric-code">VC</p>

									<div class="impact-choices">
										<label>
											<input type="radio" name="VC" value="N" data-label="Aucun" />
											<span>Aucun</span>
										</label>

										<label>
											<input type="radio" name="VC" value="L" data-label="Faible" />
											<span>Faible</span>
										</label>

										<label>
											<input
												type="radio"
												name="VC"
												value="H"
												data-label="Élevé"
												checked
											/>
											<span>Élevé</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="impact-card">
									<legend>Intégrité</legend>
									<p class="metric-code">VI</p>

									<div class="impact-choices">
										<label>
											<input type="radio" name="VI" value="N" data-label="Aucun" />
											<span>Aucun</span>
										</label>

										<label>
											<input type="radio" name="VI" value="L" data-label="Faible" />
											<span>Faible</span>
										</label>

										<label>
											<input
												type="radio"
												name="VI"
												value="H"
												data-label="Élevé"
												checked
											/>
											<span>Élevé</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="impact-card">
									<legend>Disponibilité</legend>
									<p class="metric-code">VA</p>

									<div class="impact-choices">
										<label>
											<input type="radio" name="VA" value="N" data-label="Aucun" />
											<span>Aucun</span>
										</label>

										<label>
											<input type="radio" name="VA" value="L" data-label="Faible" />
											<span>Faible</span>
										</label>

										<label>
											<input
												type="radio"
												name="VA"
												value="H"
												data-label="Élevé"
												checked
											/>
											<span>Élevé</span>
										</label>
									</div>
								</fieldset>
							</div>
						</div>
					</section>

					<section class="metric-section">
						<div class="section-number">3</div>

						<div class="section-content">
							<div class="section-heading">
								<p>Systèmes suivants</p>
								<h2>L’exploitation affecte-t-elle d’autres composants ?</h2>
							</div>

							<div class="impact-grid">
								<fieldset class="impact-card">
									<legend>Confidentialité</legend>
									<p class="metric-code">SC</p>

									<div class="impact-choices">
										<label>
											<input
												type="radio"
												name="SC"
												value="N"
												data-label="Aucun"
												checked
											/>
											<span>Aucun</span>
										</label>

										<label>
											<input type="radio" name="SC" value="L" data-label="Faible" />
											<span>Faible</span>
										</label>

										<label>
											<input type="radio" name="SC" value="H" data-label="Élevé" />
											<span>Élevé</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="impact-card">
									<legend>Intégrité</legend>
									<p class="metric-code">SI</p>

									<div class="impact-choices">
										<label>
											<input
												type="radio"
												name="SI"
												value="N"
												data-label="Aucun"
												checked
											/>
											<span>Aucun</span>
										</label>

										<label>
											<input type="radio" name="SI" value="L" data-label="Faible" />
											<span>Faible</span>
										</label>

										<label>
											<input type="radio" name="SI" value="H" data-label="Élevé" />
											<span>Élevé</span>
										</label>
									</div>
								</fieldset>

								<fieldset class="impact-card">
									<legend>Disponibilité</legend>
									<p class="metric-code">SA</p>

									<div class="impact-choices">
										<label>
											<input
												type="radio"
												name="SA"
												value="N"
												data-label="Aucun"
												checked
											/>
											<span>Aucun</span>
										</label>

										<label>
											<input type="radio" name="SA" value="L" data-label="Faible" />
											<span>Faible</span>
										</label>

										<label>
											<input type="radio" name="SA" value="H" data-label="Élevé" />
											<span>Élevé</span>
										</label>
									</div>
								</fieldset>
							</div>
						</div>
					</section>
				</form>

				<aside class="result-card">
					<div class="result-top">
						<div>
							<p class="result-label">CVSS v4.0</p>
							<h2>Vecteur construit</h2>
						</div>

						<span class="status-badge">Interactif</span>
					</div>

					<div class="vector-box">
						<code id="cvss-vector">
							CVSS:4.0/AV:N/AC:L/AT:N/PR:N/UI:N/VC:H/VI:H/VA:H/SC:N/SI:N/SA:N
						</code>

						<button id="copy-vector" type="button">
							Copier le vecteur
						</button>
					</div>

					<div class="score-preview" id="score-preview">
	<div class="score-heading">
		<p>Score CVSS-B v4.0</p>
		<span id="severity-badge">—</span>
	</div>

	<strong id="cvss-score">—</strong>

	<span id="score-description">
		Score calculé à partir de l’implémentation de référence publiée par FIRST - <a href="https://www.first.org/" target="_blank" rel="noopener noreferrer">https://www.first.org/</a>.
	</span>
</div>

					<div class="explanation">
						<h3>Lecture du vecteur</h3>
						<ul id="vector-explanation"></ul>
					</div>

					<div class="important-note">
						<strong>Sévérité ≠ priorité</strong>

						<p>
							Le score CVSS mesure une sévérité technique.
							L’exposition, l’EPSS, la disponibilité d’un exploit et le
							contexte métier restent nécessaires pour définir une priorité.
						</p>
					</div>

					<p class="cvss-attribution">
	CVSS® est une marque et un standard maintenus par FIRST.Org, Inc.
	Ce calculateur MM Labs utilise l’implémentation de référence CVSS v4.0
	publiée par FIRST. MM Labs n’est ni affilié à FIRST ni approuvé par FIRST.
</p>
				</aside>
			</div>
		</main>

		<Footer />

<script is:inline src="/vendor/cvss4/cvss_config.js"></script>
<script is:inline src="/vendor/cvss4/cvss_details.js"></script>
<script is:inline src="/vendor/cvss4/cvss_lookup.js"></script>
<script is:inline src="/vendor/cvss4/cvss_score.js"></script>
<script is:inline src="/vendor/cvss4/max_composed.js"></script>
<script is:inline src="/vendor/cvss4/max_severity.js"></script>
<script is:inline src="/vendor/cvss4/metrics.js"></script>



		<script>
	const form =
		document.querySelector<HTMLFormElement>('#cvss-form');

	const vectorElement =
		document.querySelector<HTMLElement>('#cvss-vector');

	const explanationList =
		document.querySelector<HTMLUListElement>(
			'#vector-explanation'
		);

	const copyButton =
		document.querySelector<HTMLButtonElement>(
			'#copy-vector'
		);

	const scoreElement =
		document.querySelector<HTMLElement>('#cvss-score');

	const severityBadge =
		document.querySelector<HTMLElement>(
			'#severity-badge'
		);

	const scorePreview =
		document.querySelector<HTMLElement>(
			'#score-preview'
		);

	const scoreDescription =
		document.querySelector<HTMLElement>(
			'#score-description'
		);

	const metricOrder = [
		'AV',
		'AC',
		'AT',
		'PR',
		'UI',
		'VC',
		'VI',
		'VA',
		'SC',
		'SI',
		'SA',
	];

	const metricNames: Record<string, string> = {
		AV: 'Vecteur d’attaque',
		AC: 'Complexité de l’attaque',
		AT: 'Conditions d’attaque',
		PR: 'Privilèges requis',
		UI: 'Interaction utilisateur',
		VC: 'Confidentialité du système vulnérable',
		VI: 'Intégrité du système vulnérable',
		VA: 'Disponibilité du système vulnérable',
		SC: 'Confidentialité des systèmes suivants',
		SI: 'Intégrité des systèmes suivants',
		SA: 'Disponibilité des systèmes suivants',
	};

	interface FirstCvssGlobals extends Window {
		cvss_score?: (
			metrics: Record<string, string>,
			lookup: Record<string, number>,
			maxSeverity: unknown,
			macroVector: string
		) => number;

		cvssLookup_global?: Record<string, number>;
		maxSeverity?: unknown;

		macroVector?: (
			metrics: Record<string, string>
		) => string;
	}

	const firstWindow =
		window as unknown as FirstCvssGlobals;

	const getSelectedInput = (
		metric: string
	): HTMLInputElement | null =>
		form?.querySelector<HTMLInputElement>(
			`input[name="${metric}"]:checked`
		) ?? null;

	const getBaseMetrics = (): Record<string, string> => {
		const selected: Record<string, string> = {};

		metricOrder.forEach((metric) => {
			selected[metric] =
				getSelectedInput(metric)?.value ?? 'X';
		});

		/*
		 * Valeurs par défaut officielles pour les groupes
		 * Threat, Environmental et Supplemental.
		 *
		 * X signifie Not Defined.
		 */
		Object.assign(selected, {
			E: 'X',

			CR: 'X',
			IR: 'X',
			AR: 'X',

			MAV: 'X',
			MAC: 'X',
			MAT: 'X',
			MPR: 'X',
			MUI: 'X',

			MVC: 'X',
			MVI: 'X',
			MVA: 'X',
			MSC: 'X',
			MSI: 'X',
			MSA: 'X',

			S: 'X',
			AU: 'X',
			R: 'X',
			V: 'X',
			RE: 'X',
			U: 'X',
		});

		return selected;
	};

	const buildVector = (): string => {
		const metrics = metricOrder.map((metric) => {
			const input = getSelectedInput(metric);

			return `${metric}:${input?.value ?? 'X'}`;
		});

		return `CVSS:4.0/${metrics.join('/')}`;
	};

	const getSeverity = (
		score: number
	): {
		label: string;
		className: string;
		description: string;
	} => {
		if (score === 0) {
			return {
				label: 'Aucune',
				className: 'none',
				description:
					'Aucun impact mesurable selon les métriques sélectionnées.',
			};
		}

		if (score < 4) {
			return {
				label: 'Faible',
				className: 'low',
				description:
					'Sévérité technique faible selon CVSS v4.0.',
			};
		}

		if (score < 7) {
			return {
				label: 'Modérée',
				className: 'medium',
				description:
					'Sévérité technique modérée selon CVSS v4.0.',
			};
		}

		if (score < 9) {
			return {
				label: 'Élevée',
				className: 'high',
				description:
					'Sévérité technique élevée selon CVSS v4.0.',
			};
		}

		return {
			label: 'Critique',
			className: 'critical',
			description:
				'Sévérité technique critique selon CVSS v4.0.',
		};
	};

	const calculateOfficialScore = (): number | null => {
		const {
			cvss_score,
			cvssLookup_global,
			maxSeverity,
			macroVector,
		} = firstWindow;

		if (
			typeof cvss_score !== 'function' ||
			typeof macroVector !== 'function' ||
			!cvssLookup_global ||
			!maxSeverity
		) {
			console.error(
				'Le moteur officiel CVSS v4.0 de FIRST n’est pas disponible.'
			);

			return null;
		}

		const metrics = getBaseMetrics();
		const macro = macroVector(metrics);

		const score = cvss_score(
			metrics,
			cvssLookup_global,
			maxSeverity,
			macro
		);

		return Number.isFinite(score)
			? Number(score)
			: null;
	};

	const updateExplanation = (): void => {
		if (!explanationList) return;

		explanationList.replaceChildren();

		metricOrder.forEach((metric) => {
			const input = getSelectedInput(metric);
			const item = document.createElement('li');

			const title =
				document.createElement('strong');

			title.textContent = metricNames[metric];

			const value =
				document.createElement('span');

			value.textContent =
				input?.dataset.label ?? 'Non défini';

			item.append(title, value);
			explanationList.appendChild(item);
		});
	};

	const updateOfficialScore = (): void => {
		if (
			!scoreElement ||
			!severityBadge ||
			!scorePreview ||
			!scoreDescription
		) {
			return;
		}

		const score = calculateOfficialScore();

		scorePreview.classList.remove(
			'none',
			'low',
			'medium',
			'high',
			'critical',
			'error'
		);

		if (score === null) {
			scoreElement.textContent = '—';
			severityBadge.textContent = 'Erreur';
			scorePreview.classList.add('error');

			scoreDescription.textContent =
				'Le moteur de calcul CVSS v4.0 n’a pas pu être chargé.';

			return;
		}

		const severity = getSeverity(score);

		scoreElement.textContent = score.toFixed(1);
		severityBadge.textContent = severity.label;

		scoreDescription.textContent =
			`${severity.description} Score calculé avec l’implémentation de référence publiée par FIRST.`;

		scorePreview.classList.add(
			severity.className
		);
	};

	const updateCalculator = (): void => {
		const vector = buildVector();

		if (vectorElement) {
			vectorElement.textContent = vector;
		}

		updateExplanation();
		updateOfficialScore();
	};

	form?.addEventListener(
		'change',
		updateCalculator
	);

	copyButton?.addEventListener(
		'click',
		async () => {
			if (!vectorElement) return;

			const score =
				scoreElement?.textContent ?? '—';

			const severity =
				severityBadge?.textContent ?? '—';

			const content =
				`${vectorElement.textContent}\n` +
				`CVSS-B v4.0 : ${score} — ${severity}`;

			try {
				await navigator.clipboard.writeText(
					content
				);

				copyButton.textContent =
					'Score et vecteur copiés';

				window.setTimeout(() => {
					copyButton.textContent =
						'Copier le vecteur';
				}, 1800);
			} catch (error) {
				console.error(
					'Impossible de copier le résultat.',
					error
