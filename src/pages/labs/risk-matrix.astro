---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`MM Risk Score | ${SITE_TITLE}`}
			description="Un formulaire guidé pour analyser un scénario de risque cybersécurité à partir du contexte, de l’exploitabilité, de l’impact potentiel et des contrôles compensatoires."
		/>
	</head>

<<script>
	import {
		calculateRisk,
		type RiskInput,
		type RiskResult,
	} from '../../lib/riskEngine';

	import { exportRiskPdf } from '../../lib/riskPdf';

	const STORAGE_KEY = 'mm-risk-score-draft-v2';

	const form =
		document.querySelector<HTMLFormElement>('#risk-form');

	const calculateButton =
		document.querySelector<HTMLButtonElement>('#calculate-risk');

	const clearDraftButton =
		document.querySelector<HTMLButtonElement>('#clear-risk-draft');

	const resultSection =
		document.querySelector<HTMLElement>('#risk-result');

	const copyButton =
		document.querySelector<HTMLButtonElement>('#copy-analysis');

	const exportPdfButton =
		document.querySelector<HTMLButtonElement>('#export-risk-pdf');

	const draftStatus =
		document.querySelector<HTMLElement>('#draft-status');

	let lastInput: RiskInput | null = null;
	let lastResult: RiskResult | null = null;
	let saveTimer: number | undefined;

	if (!form || !calculateButton || !resultSection) {
		console.error(
			'MM Risk Score : certains éléments nécessaires sont absents de la page.'
		);
	} else {
		const getChecked = (name: string): boolean => {
			const input =
				form.querySelector<HTMLInputElement>(
					`input[name="${name}"]`
				);

			return Boolean(input?.checked);
		};

		const getRadioValue = (name: string): string => {
			const input =
				form.querySelector<HTMLInputElement>(
					`input[name="${name}"]:checked`
				);

			return input?.value ?? '';
		};

		const setText = (
			selector: string,
			value: string
		): void => {
			const element =
				document.querySelector<HTMLElement>(selector);

			if (element) {
				element.textContent = value;
			}
		};

		const normalizeLevel = (level: string): string =>
			level
				.toLowerCase()
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '');

		const setUnorderedList = (
			selector: string,
			items: string[],
			emptyMessage: string
		): void => {
			const list =
				document.querySelector<HTMLUListElement>(selector);

			if (!list) return;

			list.replaceChildren();

			const values =
				items.length > 0 ? items : [emptyMessage];

			values.forEach((item) => {
				const listItem =
					document.createElement('li');

				listItem.textContent = item;
				list.appendChild(listItem);
			});
		};

		const setOrderedList = (
			selector: string,
			items: string[],
			emptyMessage: string
		): void => {
			const list =
				document.querySelector<HTMLOListElement>(selector);

			if (!list) return;

			list.replaceChildren();

			const values =
				items.length > 0 ? items : [emptyMessage];

			values.forEach((item) => {
				const listItem =
					document.createElement('li');

				listItem.textContent = item;
				list.appendChild(listItem);
			});
		};

		const getAssetLabel = (value: string): string => {
			const labels: Record<string, string> = {
				workstation: 'Poste utilisateur',
				server: 'Serveur',
				'web-application': 'Application web',
				api: 'API',
				database: 'Base de données',
				'active-directory': 'Active Directory',
				cloud: 'Ressource Cloud',
				ot: 'Équipement OT',
			};

			return labels[value] ?? value;
		};

		const getExposureLabel = (value: string): string => {
			const labels: Record<string, string> = {
				internet: 'Internet',
				partner: 'Partenaire / Extranet',
				vpn: 'VPN',
				internal: 'Réseau interne',
				isolated: 'Isolé / Segmenté',
			};

			return labels[value] ?? value;
		};

		const getCriticalityLabel = (
			value: number
		): string => {
			const labels: Record<number, string> = {
				1: 'Faible',
				2: 'Modérée',
				3: 'Importante',
				4: 'Critique',
			};

			return labels[value] ?? `${value}/4`;
		};

		const yesNo = (value: boolean): string =>
			value ? 'Oui' : 'Non';

		const showDraftStatus = (
			message: string,
			timeout = 1800
		): void => {
			if (!draftStatus) return;

			draftStatus.textContent = message;

			if (timeout > 0) {
				window.setTimeout(() => {
					draftStatus.textContent =
						'Le brouillon est sauvegardé automatiquement sur cet appareil.';
				}, timeout);
			}
		};

		const readForm = (
			validate = true
		): RiskInput | null => {
			const scenario =
				form
					.querySelector<HTMLTextAreaElement>(
						'#scenario'
					)
					?.value.trim() ?? '';

			const assetType =
				form
					.querySelector<HTMLSelectElement>(
						'#asset-type'
					)
					?.value ?? '';

			const exposure =
				form
					.querySelector<HTMLSelectElement>(
						'#exposure'
					)
					?.value ?? '';

			const criticalityValue =
				getRadioValue('criticality');

			const publicExploitValue =
				getRadioValue('publicExploit');

			const authenticationValue =
				getRadioValue(
					'authenticationRequired'
				);

			const cvssRaw =
				form
					.querySelector<HTMLInputElement>(
						'#cvss'
					)
					?.value ?? '';

			const epssRaw =
				form
					.querySelector<HTMLInputElement>(
						'#epss'
					)
					?.value ?? '';

			const cvss = Number(cvssRaw || 0);
			const epss = Number(epssRaw || 0);
			const criticality =
				Number(criticalityValue || 0);

			if (
				validate &&
				(
					!scenario ||
					!assetType ||
					!exposure ||
					!criticalityValue ||
					!publicExploitValue ||
					!authenticationValue ||
					cvssRaw === '' ||
					epssRaw === ''
				)
			) {
				window.alert(
					'Complète tous les champs obligatoires du contexte et de l’exploitabilité.'
				);

				return null;
			}

			if (
				validate &&
				(
					!Number.isFinite(cvss) ||
					cvss < 0 ||
					cvss > 10
				)
			) {
				window.alert(
					'Le score CVSS doit être compris entre 0 et 10.'
				);

				return null;
			}

			if (
				validate &&
				(
					!Number.isFinite(epss) ||
					epss < 0 ||
					epss > 100
				)
			) {
				window.alert(
					'Le score EPSS doit être compris entre 0 et 100 %.'
				);

				return null;
			}

			return {
				scenario,
				assetType,
				exposure,
				criticality,
				cvss,
				epss,

				publicExploit:
					publicExploitValue === 'yes',

				authenticationRequired:
					authenticationValue === 'yes',

				sensitiveData:
					getChecked('sensitiveData'),

				businessInterruption:
					getChecked(
						'businessInterruption'
					),

				privilegedAccess:
					getChecked('privilegedAccess'),

				lateralMovement:
					getChecked('lateralMovement'),

				controls: {
					edr: getChecked('edr'),
					waf: getChecked('waf'),
					mfa: getChecked('mfa'),

					segmentation:
						getChecked('segmentation'),

					backups:
						getChecked('backups'),

					soc: getChecked('soc'),
				},
			};
		};

		const applyRadioValue = (
			name: string,
			value: string
		): void => {
			const inputs =
				form.querySelectorAll<HTMLInputElement>(
					`input[name="${name}"]`
				);

			inputs.forEach((input) => {
				input.checked =
					input.value === value;
			});
		};

		const applyCheckboxValue = (
			name: string,
			value: boolean
		): void => {
			const input =
				form.querySelector<HTMLInputElement>(
					`input[name="${name}"]`
				);

			if (input) {
				input.checked = value;
			}
		};

		const saveDraft = (): void => {
			const input = readForm(false);

			if (!input) return;

			try {
				localStorage.setItem(
					STORAGE_KEY,
					JSON.stringify(input)
				);

				showDraftStatus(
					'Brouillon sauvegardé.',
					1200
				);
			} catch (error) {
				console.error(
					'Impossible de sauvegarder le brouillon.',
					error
				);

				showDraftStatus(
					'Sauvegarde locale impossible.'
				);
			}
		};

		const scheduleDraftSave = (): void => {
			window.clearTimeout(saveTimer);

			saveTimer = window.setTimeout(
				saveDraft,
				350
			);
		};

		const restoreDraft = (): void => {
			const serialized =
				localStorage.getItem(STORAGE_KEY);

			if (!serialized) return;

			try {
				const draft =
					JSON.parse(serialized) as RiskInput;

				const scenario =
					form.querySelector<HTMLTextAreaElement>(
						'#scenario'
					);

				const assetType =
					form.querySelector<HTMLSelectElement>(
						'#asset-type'
					);

				const exposure =
					form.querySelector<HTMLSelectElement>(
						'#exposure'
					);

				const cvss =
					form.querySelector<HTMLInputElement>(
						'#cvss'
					);

				const epss =
					form.querySelector<HTMLInputElement>(
						'#epss'
					);

				if (scenario) {
					scenario.value =
						draft.scenario ?? '';
				}

				if (assetType) {
					assetType.value =
						draft.assetType ?? '';
				}

				if (exposure) {
					exposure.value =
						draft.exposure ?? '';
				}

				if (cvss) {
					cvss.value =
						String(draft.cvss ?? '');
				}

				if (epss) {
					epss.value =
						String(draft.epss ?? '');
				}

				applyRadioValue(
					'criticality',
					String(draft.criticality ?? '')
				);

				applyRadioValue(
					'publicExploit',
					draft.publicExploit
						? 'yes'
						: 'no'
				);

				applyRadioValue(
					'authenticationRequired',
					draft.authenticationRequired
						? 'yes'
						: 'no'
				);

				applyCheckboxValue(
					'sensitiveData',
					Boolean(draft.sensitiveData)
				);

				applyCheckboxValue(
					'businessInterruption',
					Boolean(
						draft.businessInterruption
					)
				);

				applyCheckboxValue(
					'privilegedAccess',
					Boolean(draft.privilegedAccess)
				);

				applyCheckboxValue(
					'lateralMovement',
					Boolean(draft.lateralMovement)
				);

				applyCheckboxValue(
					'edr',
					Boolean(draft.controls?.edr)
				);

				applyCheckboxValue(
					'waf',
					Boolean(draft.controls?.waf)
				);

				applyCheckboxValue(
					'mfa',
					Boolean(draft.controls?.mfa)
				);

				applyCheckboxValue(
					'segmentation',
					Boolean(
						draft.controls?.segmentation
					)
				);

				applyCheckboxValue(
					'backups',
					Boolean(
						draft.controls?.backups
					)
				);

				applyCheckboxValue(
					'soc',
					Boolean(draft.controls?.soc)
				);

				showDraftStatus(
					'Brouillon restauré.',
					1800
				);
			} catch (error) {
				console.error(
					'Impossible de restaurer le brouillon.',
					error
				);

				localStorage.removeItem(
					STORAGE_KEY
				);
			}
		};

		const clearDraft = (): void => {
			localStorage.removeItem(STORAGE_KEY);

			form.reset();

			lastInput = null;
			lastResult = null;

			resultSection.hidden = true;
			resultSection.classList.remove(
				'is-visible'
			);

			showDraftStatus(
				'Brouillon effacé.',
				1800
			);

			window.scrollTo({
				top: form.offsetTop - 100,
				behavior: 'smooth',
			});
		};

		const renderResult = (
			result: RiskResult
		): void => {
			setText(
				'#result-score',
				String(result.score)
			);

			setText(
				'#result-level',
				result.level
			);

			setText(
				'#result-priority',
				result.priority
			);

			setText(
				'#result-deadline',
				result.deadline
			);

			setText(
				'#result-probability',
				String(result.probability)
			);

			setText(
				'#result-impact',
				String(result.impact)
			);

			setText(
				'#result-reduction',
				String(result.controlReduction)
			);

			setText(
				'#result-summary',
				result.summary
			);

			const progressBar =
				document.querySelector<HTMLElement>(
					'#score-progress-bar'
				);

			if (progressBar) {
				progressBar.style.width = '0%';

				requestAnimationFrame(() => {
					progressBar.style.width =
						`${result.score}%`;
				});
			}

			resultSection.dataset.level =
				normalizeLevel(result.level);

			setUnorderedList(
				'#risk-factors-list',
				result.riskFactors,
				'Aucun facteur aggravant majeur identifié.'
			);

			setUnorderedList(
				'#protective-factors-list',
				result.protectiveFactors,
				'Aucun contrôle compensatoire déclaré.'
			);

			setOrderedList(
				'#recommendations-list',
				result.recommendations,
				'Documenter le scénario et organiser une revue du risque.'
			);

			resultSection.hidden = false;

			requestAnimationFrame(() => {
				resultSection.classList.add(
					'is-visible'
				);
			});

			window.setTimeout(() => {
				resultSection.scrollIntoView({
					behavior: 'smooth',
					block: 'start',
				});
			}, 100);
		};

		const buildCompleteReport = (
			input: RiskInput,
			result: RiskResult
		): string => {
			const riskFactors =
				result.riskFactors.length > 0
					? result.riskFactors
							.map(
								(item) => `- ${item}`
							)
							.join('\n')
					: '- Aucun facteur aggravant majeur identifié.';

			const protectiveFactors =
				result.protectiveFactors.length > 0
					? result.protectiveFactors
							.map(
								(item) => `- ${item}`
							)
							.join('\n')
					: '- Aucun contrôle compensatoire déclaré.';

			const recommendations =
				result.recommendations.length > 0
					? result.recommendations
							.map(
								(item, index) =>
									`${index + 1}. ${item}`
							)
							.join('\n')
					: '1. Documenter le scénario et organiser une revue du risque.';

			return `MM Risk Score
===============

SCÉNARIO
--------
${input.scenario}

CONTEXTE
--------
Type d’actif : ${getAssetLabel(input.assetType)}
Exposition : ${getExposureLabel(input.exposure)}
Criticité métier : ${getCriticalityLabel(input.criticality)}

EXPLOITABILITÉ
--------------
CVSS : ${input.cvss.toFixed(1)}/10
EPSS : ${input.epss.toFixed(1)} %
Exploit public disponible : ${yesNo(input.publicExploit)}
Authentification nécessaire : ${yesNo(input.authenticationRequired)}

IMPACT POTENTIEL
----------------
Données sensibles : ${yesNo(input.sensitiveData)}
Interruption métier importante : ${yesNo(input.businessInterruption)}
Privilèges élevés : ${yesNo(input.privilegedAccess)}
Mouvement latéral possible : ${yesNo(input.lateralMovement)}

CONTRÔLES COMPENSATOIRES
------------------------
EDR : ${yesNo(input.controls.edr)}
WAF : ${yesNo(input.controls.waf)}
MFA : ${yesNo(input.controls.mfa)}
Segmentation : ${yesNo(input.controls.segmentation)}
Sauvegardes : ${yesNo(input.controls.backups)}
Supervision SOC : ${yesNo(input.controls.soc)}

RÉSULTAT
--------
MM Risk Score : ${result.score}/100
Niveau : ${result.level}
Priorité : ${result.priority}
Délai conseillé : ${result.deadline}

Probabilité calculée : ${result.probability}/5
Impact calculé : ${result.impact}/5
Réduction apportée par les contrôles : -${result.controlReduction} point${result.controlReduction > 1 ? 's' : ''}

ANALYSE AUTOMATIQUE
-------------------
${result.summary}

FACTEURS AUGMENTANT LE RISQUE
-----------------------------
${riskFactors}

CONTRÔLES PROTECTEURS
---------------------
${protectiveFactors}

PRIORITÉS RECOMMANDÉES
----------------------
${recommendations}

AVERTISSEMENT
-------------
Le MM Risk Score est une méthode d’aide à la décision. Il fournit une estimation contextualisée à partir des informations renseignées, mais ne remplace pas une analyse de risque complète et ne constitue pas un standard officiel.`;
		};

		calculateButton.addEventListener(
			'click',
			() => {
				const input = readForm(true);

				if (!input) return;

				const result =
					calculateRisk(input);

				lastInput = input;
				lastResult = result;

				saveDraft();
				renderResult(result);
			}
		);

		copyButton?.addEventListener(
			'click',
			async () => {
				if (!lastInput || !lastResult) {
					copyButton.textContent =
						'Aucune analyse disponible';

					window.setTimeout(() => {
						copyButton.textContent =
							'Copier l’analyse';
					}, 1800);

					return;
				}

				const report =
					buildCompleteReport(
						lastInput,
						lastResult
					);

				try {
					await navigator.clipboard.writeText(
						report
					);

					copyButton.textContent =
						'Analyse complète copiée';
				} catch (error) {
					console.error(
						'Impossible de copier l’analyse.',
						error
					);

					copyButton.textContent =
						'Copie impossible';
				}

				window.setTimeout(() => {
					copyButton.textContent =
						'Copier l’analyse';
				}, 1800);
			}
		);

		exportPdfButton?.addEventListener(
			'click',
			() => {
				if (!lastInput || !lastResult) {
					exportPdfButton.textContent =
						'Calcule d’abord le score';

					window.setTimeout(() => {
						exportPdfButton.textContent =
							'Exporter en PDF';
					}, 1800);

					return;
				}

				try {
					exportPdfButton.disabled = true;
					exportPdfButton.textContent =
						'Génération du PDF...';

					exportRiskPdf(
						lastInput,
						lastResult
					);

					exportPdfButton.textContent =
						'PDF téléchargé';
				} catch (error) {
					console.error(
						'Impossible de générer le PDF.',
						error
					);

					exportPdfButton.textContent =
						'Export impossible';
				} finally {
					window.setTimeout(() => {
						exportPdfButton.disabled = false;
						exportPdfButton.textContent =
							'Exporter en PDF';
					}, 1800);
				}
			}
		);

		clearDraftButton?.addEventListener(
			'click',
			clearDraft
		);

		form.addEventListener(
			'input',
			scheduleDraftSave
		);

		form.addEventListener(
			'change',
			scheduleDraftSave
		);

		restoreDraft();
	}
</script>

	<body>
		<Header />

		<main>
			<section class="hero">
	<p class="tag">LABS</p>

	<h1>MM Risk Score</h1>

	<p class="hero-intro">
		Un formulaire guidé pour évaluer un scénario de risque à partir
		d’éléments factuels, sans demander à l’utilisateur de choisir lui-même
		la probabilité ou l’impact.
	</p>

	<div class="method-disclaimer">
		<strong>Méthode d’aide à la décision</strong>

		<p>
			Le MM Risk Score fournit une estimation contextualisée à partir des
			informations renseignées. Il ne remplace pas une analyse de risque
			complète et ne constitue pas un standard officiel.
		</p>
	</div>
</section>

			<form class="risk-form" id="risk-form">
				<section class="form-section">
					<div class="section-number">1</div>

					<div class="section-content">
						<div class="section-heading">
							<p>Contexte</p>
							<h2>Décrire le scénario</h2>
						</div>

						<div class="fields-grid">
							<div class="field field-wide">
								<label for="scenario">Scénario</label>
								<textarea
									id="scenario"
									name="scenario"
									placeholder="Exemple : serveur web exposé sur Internet avec une vulnérabilité critique"
								></textarea>
							</div>

							<div class="field">
								<label for="asset-type">Type d’actif</label>
								<select id="asset-type" name="assetType">
									<option value="">Sélectionner</option>
									<option value="workstation">Poste utilisateur</option>
									<option value="server">Serveur</option>
									<option value="web-application">Application web</option>
									<option value="api">API</option>
									<option value="database">Base de données</option>
									<option value="active-directory">Active Directory</option>
									<option value="cloud">Ressource Cloud</option>
									<option value="ot">Équipement OT</option>
								</select>
							</div>

							<div class="field">
								<label for="exposure">Exposition</label>
								<select id="exposure" name="exposure">
									<option value="">Sélectionner</option>
									<option value="internet">Internet</option>
									<option value="partner">Partenaire / Extranet</option>
									<option value="vpn">VPN</option>
									<option value="internal">Réseau interne</option>
									<option value="isolated">Isolé / Segmenté</option>
								</select>
							</div>

							<div class="field field-wide">
								<label>Criticité métier</label>

								<div class="choice-grid four">
									<label class="choice-card">
										<input type="radio" name="criticality" value="1" />
										<span>
											<strong>Faible</strong>
											<small>Impact limité</small>
										</span>
									</label>

									<label class="choice-card">
										<input type="radio" name="criticality" value="2" />
										<span>
											<strong>Modérée</strong>
											<small>Service non critique</small>
										</span>
									</label>

									<label class="choice-card">
										<input type="radio" name="criticality" value="3" />
										<span>
											<strong>Importante</strong>
											<small>Impact métier notable</small>
										</span>
									</label>

									<label class="choice-card">
										<input type="radio" name="criticality" value="4" />
										<span>
											<strong>Critique</strong>
											<small>Service essentiel</small>
										</span>
									</label>
								</div>
