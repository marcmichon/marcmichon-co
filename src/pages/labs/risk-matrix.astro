---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead
			title={`MM Risk Score | ${SITE_TITLE}`}
			description="Un formulaire guidé pour analyser un scénario de risque cybersécurité à partir du contexte, de l’exploitabilité, de l’impact potentiel et des contrôles compensatoires."
		/>
	</head>

<script>
	import { calculateRisk } from '../../lib/riskEngine';

	const form = document.querySelector<HTMLFormElement>('#risk-form');
	const calculateButton =
		document.querySelector<HTMLButtonElement>('#calculate-risk');
	const resultSection =
		document.querySelector<HTMLElement>('#risk-result');

	if (!form || !calculateButton || !resultSection) {
		throw new Error('Impossible d’initialiser le MM Risk Score.');
	}

	const getChecked = (name: string): boolean => {
		const input =
			form.querySelector<HTMLInputElement>(`input[name="${name}"]`);

		return Boolean(input?.checked);
	};

	const getRadioValue = (name: string): string => {
		const input =
			form.querySelector<HTMLInputElement>(
				`input[name="${name}"]:checked`
			);

		return input?.value ?? '';
	};

	const setList = (
		selector: string,
		items: string[],
		emptyMessage: string
	): void => {
		const list = document.querySelector<HTMLUListElement>(selector);

		if (!list) return;

		list.innerHTML = '';

		const values = items.length > 0 ? items : [emptyMessage];

		values.forEach((item) => {
			const element = document.createElement('li');
			element.textContent = item;
			list.appendChild(element);
		});
	};

	const setOrderedList = (
		selector: string,
		items: string[]
	): void => {
		const list = document.querySelector<HTMLOListElement>(selector);

		if (!list) return;

		list.innerHTML = '';

		const values =
			items.length > 0
				? items
				: ['Documenter le scénario et organiser une revue du risque.'];

		values.forEach((item) => {
			const element = document.createElement('li');
			element.textContent = item;
			list.appendChild(element);
		});
	};

	calculateButton.addEventListener('click', () => {
		const scenario =
			form.querySelector<HTMLTextAreaElement>('#scenario')?.value.trim() ?? '';

		const assetType =
			form.querySelector<HTMLSelectElement>('#asset-type')?.value ?? '';

		const exposure =
			form.querySelector<HTMLSelectElement>('#exposure')?.value ?? '';

		const criticality = Number(getRadioValue('criticality'));

		const cvss = Number(
			form.querySelector<HTMLInputElement>('#cvss')?.value ?? 0
		);

		const epss = Number(
			form.querySelector<HTMLInputElement>('#epss')?.value ?? 0
		);

		const publicExploit =
			getRadioValue('publicExploit') === 'yes';

		const authenticationRequired =
			getRadioValue('authenticationRequired') === 'yes';

		if (
			!scenario ||
			!assetType ||
			!exposure ||
			!criticality ||
			!getRadioValue('publicExploit') ||
			!getRadioValue('authenticationRequired')
		) {
			alert(
				'Complète le scénario, le type d’actif, l’exposition, la criticité métier et les deux questions d’exploitabilité.'
			);

			return;
		}

		if (
			Number.isNaN(cvss) ||
			cvss < 0 ||
			cvss > 10 ||
			Number.isNaN(epss) ||
			epss < 0 ||
			epss > 100
		) {
			alert(
				'Le CVSS doit être compris entre 0 et 10 et l’EPSS entre 0 et 100 %.'
			);

			return;
		}

		const input = {
			scenario,
			assetType,
			exposure,
			criticality,
			cvss,
			epss,
			publicExploit,
			authenticationRequired,
			sensitiveData: getChecked('sensitiveData'),
			businessInterruption: getChecked('businessInterruption'),
			privilegedAccess: getChecked('privilegedAccess'),
			lateralMovement: getChecked('lateralMovement'),
			controls: {
				edr: getChecked('edr'),
				waf: getChecked('waf'),
				mfa: getChecked('mfa'),
				segmentation: getChecked('segmentation'),
				backups: getChecked('backups'),
				soc: getChecked('soc'),
			},
		};

		const result = calculateRisk(input);

		document.querySelector('#result-score')!.textContent =
			String(result.score);

		document.querySelector('#result-level')!.textContent =
			result.level;

		document.querySelector('#result-priority')!.textContent =
			result.priority;

		document.querySelector('#result-deadline')!.textContent =
			result.deadline;

		document.querySelector('#result-probability')!.textContent =
			String(result.probability);

		document.querySelector('#result-impact')!.textContent =
			String(result.impact);

		document.querySelector('#result-reduction')!.textContent =
			String(result.controlReduction);

		document.querySelector('#result-summary')!.textContent =
			result.summary;

		const progressBar =
			document.querySelector<HTMLElement>('#score-progress-bar');

		if (progressBar) {
			progressBar.style.width = `${result.score}%`;
		}

		resultSection.dataset.level =
			result.level.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');

		setList(
			'#risk-factors-list',
			result.riskFactors,
			'Aucun facteur aggravant majeur identifié.'
		);

		setList(
			'#protective-factors-list',
			result.protectiveFactors,
			'Aucun contrôle compensatoire déclaré.'
		);

		setOrderedList(
			'#recommendations-list',
			result.recommendations
		);

		resultSection.hidden = false;

		requestAnimationFrame(() => {
			resultSection.classList.add('is-visible');
		});

		resultSection.scrollIntoView({
			behavior: 'smooth',
			block: 'start',
		});
	});

	const copyButton =
		document.querySelector<HTMLButtonElement>('#copy-analysis');

	copyButton?.addEventListener('click', async () => {
		const score =
			document.querySelector('#result-score')?.textContent ?? '';

		const level =
			document.querySelector('#result-level')?.textContent ?? '';

		const priority =
			document.querySelector('#result-priority')?.textContent ?? '';

		const deadline =
			document.querySelector('#result-deadline')?.textContent ?? '';

		const summary =
			document.querySelector('#result-summary')?.textContent ?? '';

		const content = `MM Risk Score

Score : ${score}/100
Niveau : ${level}
Priorité : ${priority}
Délai conseillé : ${deadline}

${summary}`;

		try {
			await navigator.clipboard.writeText(content);
			copyButton.textContent = 'Analyse copiée';

			window.setTimeout(() => {
				copyButton.textContent = 'Copier l’analyse';
			}, 1800);
		} catch {
			copyButton.textContent = 'Copie impossible';
		}
	});
</script>

	<body>
		<Header />

		<main>
			<section class="hero">
				<p class="tag">LABS</p>
				<h1>MM Risk Score</h1>
				<p>
					Un formulaire guidé pour évaluer un scénario de risque à partir
					d’éléments factuels, sans demander à l’utilisateur de choisir lui-même
					la probabilité ou l’impact.
				</p>
			</section>

			<form class="risk-form" id="risk-form">
				<section class="form-section">
					<div class="section-number">1</div>

					<div class="section-content">
						<div class="section-heading">
							<p>Contexte</p>
							<h2>Décrire le scénario</h2>
						</div>

						<div class="fields-grid">
							<div class="field field-wide">
								<label for="scenario">Scénario</label>
								<textarea
									id="scenario"
									name="scenario"
									placeholder="Exemple : serveur web exposé sur Internet avec une vulnérabilité critique"
								></textarea>
							</div>

							<div class="field">
								<label for="asset-type">Type d’actif</label>
								<select id="asset-type" name="assetType">
									<option value="">Sélectionner</option>
									<option value="workstation">Poste utilisateur</option>
									<option value="server">Serveur</option>
									<option value="web-application">Application web</option>
									<option value="api">API</option>
									<option value="database">Base de données</option>
									<option value="active-directory">Active Directory</option>
									<option value="cloud">Ressource Cloud</option>
									<option value="ot">Équipement OT</option>
								</select>
							</div>

							<div class="field">
								<label for="exposure">Exposition</label>
								<select id="exposure" name="exposure">
									<option value="">Sélectionner</option>
									<option value="internet">Internet</option>
									<option value="partner">Partenaire / Extranet</option>
									<option value="vpn">VPN</option>
									<option value="internal">Réseau interne</option>
									<option value="isolated">Isolé / Segmenté</option>
								</select>
							</div>

							<div class="field field-wide">
								<label>Criticité métier</label>

								<div class="choice-grid four">
									<label class="choice-card">
										<input type="radio" name="criticality" value="1" />
										<span>
											<strong>Faible</strong>
											<small>Impact limité</small>
										</span>
									</label>

									<label class="choice-card">
										<input type="radio" name="criticality" value="2" />
										<span>
											<strong>Modérée</strong>
											<small>Service non critique</small>
										</span>
									</label>

									<label class="choice-card">
										<input type="radio" name="criticality" value="3" />
										<span>
											<strong>Importante</strong>
											<small>Impact métier notable</small>
										</span>
									</label>

									<label class="choice-card">
										<input type="radio" name="criticality" value="4" />
										<span>
											<strong>Critique</strong>
											<small>Service essentiel</small>
										</span>
									</label>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="form-section">
					<div class="section-number">2</div>

					<div class="section-content">
						<div class="section-heading">
							<p>Exploitabilité</p>
							<h2>Évaluer la facilité d’exploitation</h2>
						</div>

						<div class="fields-grid">
							<div class="field">
								<label for="cvss">Score CVSS</label>
								<input
									id="cvss"
									name="cvss"
									type="number"
									min="0"
									max="10"
									step="0.1"
									placeholder="9.8"
								/>
							</div>

							<div class="field">
								<label for="epss">Score EPSS</label>
								<div class="input-suffix">
									<input
										id="epss"
										name="epss"
										type="number"
										min="0"
										max="100"
										step="0.1"
										placeholder="82"
									/>
									<span>%</span>
								</div>
							</div>

							<div class="field">
								<label>Exploit public disponible ?</label>

								<div class="binary-choice">
									<label>
										<input type="radio" name="publicExploit" value="yes" />
										<span>Oui</span>
									</label>

									<label>
										<input type="radio" name="publicExploit" value="no" />
										<span>Non</span>
									</label>
								</div>
							</div>

							<div class="field">
								<label>Authentification nécessaire ?</label>

								<div class="binary-choice">
									<label>
										<input type="radio" name="authenticationRequired" value="yes" />
										<span>Oui</span>
									</label>

									<label>
										<input type="radio" name="authenticationRequired" value="no" />
										<span>Non</span>
									</label>
								</div>
							</div>
						</div>
					</div>
				</section>

				<section class="form-section">
					<div class="section-number">3</div>

					<div class="section-content">
						<div class="section-heading">
							<p>Impact potentiel</p>
							<h2>Qualifier les conséquences possibles</h2>
						</div>

						<div class="choice-grid two">
							<label class="toggle-card">
								<input type="checkbox" name="sensitiveData" />
								<span>
									<strong>Données sensibles</strong>
									<small>Données personnelles, financières ou confidentielles</small>
								</span>
							</label>

							<label class="toggle-card">
								<input type="checkbox" name="businessInterruption" />
								<span>
									<strong>Interruption métier importante</strong>
									<small>Indisponibilité d’un service essentiel</small>
								</span>
							</label>

							<label class="toggle-card">
								<input type="checkbox" name="privilegedAccess" />
								<span>
									<strong>Privilèges élevés</strong>
									<small>Accès administrateur ou système</small>
								</span>
							</label>

							<label class="toggle-card">
								<input type="checkbox" name="lateralMovement" />
								<span>
									<strong>Mouvement latéral possible</strong>
									<small>Accès possible à d’autres actifs</small>
								</span>
							</label>
						</div>
					</div>
				</section>

				<section class="form-section">
					<div class="section-number">4</div>

					<div class="section-content">
						<div class="section-heading">
							<p>Contrôles compensatoires</p>
							<h2>Identifier les protections déjà présentes</h2>
						</div>

						<div class="choice-grid three">
							<label class="toggle-card compact">
								<input type="checkbox" name="edr" />
								<span><strong>EDR</strong></span>
							</label>

							<label class="toggle-card compact">
								<input type="checkbox" name="waf" />
								<span><strong>WAF</strong></span>
							</label>

							<label class="toggle-card compact">
								<input type="checkbox" name="mfa" />
								<span><strong>MFA</strong></span>
							</label>

							<label class="toggle-card compact">
								<input type="checkbox" name="segmentation" />
								<span><strong>Segmentation</strong></span>
							</label>

							<label class="toggle-card compact">
								<input type="checkbox" name="backups" />
								<span><strong>Sauvegardes</strong></span>
							</label>

							<label class="toggle-card compact">
								<input type="checkbox" name="soc" />
								<span><strong>Supervision SOC</strong></span>
							</label>
						</div>
					</div>
				</section>

			<div class="form-actions">
	<button id="calculate-risk" type="button">
		Calculer le MM Risk Score
	</button>

	<p>
		Le résultat est calculé à partir des informations renseignées.
	</p>
</div>
			</form>

			<section class="risk-result" id="risk-result" hidden>
	<div class="result-header">
		<div>
			<p class="result-eyebrow">ANALYSE DU SCÉNARIO</p>
			<h2>MM Risk Score</h2>
		</div>

		<div class="result-level" id="result-level">
			Élevé
		</div>
	</div>

	<div class="score-layout">
		<div class="main-score">
			<div class="score-circle">
				<strong id="result-score">0</strong>
				<span>/ 100</span>
			</div>

			<div class="score-progress">
				<div id="score-progress-bar"></div>
			</div>
		</div>

		<div class="result-metrics">
			<div class="metric">
				<span>Priorité</span>
				<strong id="result-priority">—</strong>
			</div>

			<div class="metric">
				<span>Délai conseillé</span>
				<strong id="result-deadline">—</strong>
			</div>

			<div class="metric">
				<span>Probabilité calculée</span>
				<strong><span id="result-probability">—</span>/5</strong>
			</div>

			<div class="metric">
				<span>Impact calculé</span>
				<strong><span id="result-impact">—</span>/5</strong>
			</div>

			<div class="metric">
				<span>Réduction des contrôles</span>
				<strong>-<span id="result-reduction">0</span> pts</strong>
			</div>
		</div>
	</div>

	<div class="automatic-analysis">
		<h3>Analyse automatique</h3>
		<p id="result-summary"></p>
	</div>

	<div class="analysis-columns">
		<div class="analysis-card risk-factors">
			<h3>Facteurs augmentant le risque</h3>
			<ul id="risk-factors-list"></ul>
		</div>

		<div class="analysis-card protective-factors">
			<h3>Contrôles protecteurs</h3>
			<ul id="protective-factors-list"></ul>
		</div>
	</div>

	<div class="recommendations">
		<h3>Priorités recommandées</h3>
		<ol id="recommendations-list"></ol>
	</div>

	<div class="result-actions">
		<button id="copy-analysis" type="button">
			Copier l’analyse
		</button>
	</div>
</section>

		</main>

		<Footer />
	</body>
</html>

<style>
	body {
		background: #f8fafc;
	}

	main {
		width: min(1180px, calc(100% - 4rem));
		margin: 0 auto;
		padding: 3rem 0 5rem;
	}

	.hero {
		margin-bottom: 2.5rem;
		padding: 4rem;
		border-radius: 34px;
		color: white;
		background:
			radial-gradient(circle at 80% 0%, rgba(37, 99, 235, 0.28), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		box-shadow: 0 25px 70px rgba(2, 8, 23, 0.2);
	}

	.tag {
		margin: 0;
		color: #60a5fa;
		font-size: 0.8rem;
		font-weight: 900;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.hero h1 {
		margin: 1rem 0 1.5rem;
		color: white;
		font-size: clamp(3.2rem, 6vw, 5rem);
		line-height: 0.95;
		letter-spacing: -0.06em;
	}

	.hero p:last-child {
		max-width: 780px;
		margin: 0;
		color: #dbeafe;
		font-size: 1.15rem;
		line-height: 1.75;
	}

	.risk-form {
		display: grid;
		gap: 1.5rem;
	}

	.form-section {
		display: grid;
		grid-template-columns: 64px 1fr;
		gap: 1.5rem;
		padding: 2rem;
		border: 1px solid #e5e7eb;
		border-radius: 26px;
		background: white;
		box-shadow: 0 14px 40px rgba(15, 23, 42, 0.05);
	}

	.section-number {
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		border-radius: 16px;
		background: #eff6ff;
		color: #2563eb;
		font-size: 1.2rem;
		font-weight: 900;
	}

	.section-content {
		min-width: 0;
	}

	.section-heading {
		margin-bottom: 1.75rem;
	}

	.section-heading p {
		margin: 0 0 0.3rem;
		color: #2563eb;
		font-size: 0.75rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.section-heading h2 {
		margin: 0;
		font-size: 1.8rem;
		letter-spacing: -0.04em;
	}

	.fields-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.field {
		display: grid;
		gap: 0.65rem;
		min-width: 0;
	}

	.field-wide {
		grid-column: 1 / -1;
	}

	label {
		color: #0f172a;
		font-size: 0.95rem;
		font-weight: 800;
	}

	input,
	select,
	textarea {
		width: 100%;
		box-sizing: border-box;
		border: 1px solid #cbd5e1;
		border-radius: 14px;
		padding: 0.95rem 1rem;
		background: #f8fafc;
		color: #0f172a;
		font: inherit;
	}

	textarea {
		min-height: 110px;
		resize: vertical;
	}

	input:focus-visible,
	select:focus-visible,
	textarea:focus-visible {
		outline: 3px solid rgba(37, 99, 235, 0.16);
		border-color: #2563eb;
	}

	.input-suffix {
		position: relative;
	}

	.input-suffix input {
		padding-right: 3rem;
	}

	.input-suffix span {
		position: absolute;
		top: 50%;
		right: 1rem;
		transform: translateY(-50%);
		color: #64748b;
		font-weight: 800;
	}

	.choice-grid {
		display: grid;
		gap: 1rem;
	}

	.choice-grid.four {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.choice-grid.three {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.choice-grid.two {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.choice-card,
	.toggle-card {
		position: relative;
		display: flex;
		gap: 0.8rem;
		align-items: flex-start;
		padding: 1rem;
		border: 1px solid #dbe3ef;
		border-radius: 16px;
		background: #f8fafc;
		cursor: pointer;
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			transform 0.2s ease;
	}

	.choice-card:hover,
	.toggle-card:hover {
		transform: translateY(-1px);
		border-color: #93c5fd;
		background: #eff6ff;
	}

	.choice-card input,
	.toggle-card input {
		width: auto;
		margin-top: 0.25rem;
		accent-color: #2563eb;
	}

	.choice-card span,
	.toggle-card span {
		display: grid;
		gap: 0.2rem;
	}

	.choice-card strong,
	.toggle-card strong {
		color: #0f172a;
	}

	.choice-card small,
	.toggle-card small {
		color: #64748b;
		font-size: 0.82rem;
		line-height: 1.4;
	}

	.toggle-card.compact {
		align-items: center;
		min-height: 68px;
	}

	.binary-choice {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75rem;
	}

	.binary-choice label {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.9rem;
		border: 1px solid #dbe3ef;
		border-radius: 14px;
		background: #f8fafc;
		cursor: pointer;
	}

	.binary-choice input {
