---
import {
  buildExecutiveBrief,
  type IntelligenceContext,
} from "../../lib/intelligence";

interface ScenarioSource {
  id: string;
  name: string;
  description: string;
}

interface Scenario {
  source: ScenarioSource;
  context: IntelligenceContext<ScenarioSource>;
}

const scenarios: Scenario[] = [
  createScenario(
    {
      id: "known-exploited-critical",
      name: "Known exploited critical vulnerability",
      description:
        "Critical CVSS, low EPSS, but confirmed exploitation through CISA KEV.",
    },
    {
      cvssScore: 10,
      hasCvssVector: true,
      epssProbability: 0.08,
      isKnownExploited: true,
      hasWeaknessClassification: true,
      sourceCount: 4,
      referenceCount: 15,
      hasDescription: true,
      hasTimeline: true,
    },
  ),

  createScenario(
    {
      id: "critical-unconfirmed",
      name: "Critical but not known exploited",
      description:
        "Critical technical severity with a low current exploitation probability.",
    },
    {
      cvssScore: 9.8,
      hasCvssVector: true,
      epssProbability: 0.01,
      isKnownExploited: false,
      hasWeaknessClassification: true,
      sourceCount: 3,
      referenceCount: 8,
      hasDescription: true,
      hasTimeline: true,
    },
  ),

  createScenario(
    {
      id: "high-exploitation-probability",
      name: "High exploitation probability",
      description:
        "High severity combined with a very high EPSS probability.",
    },
    {
      cvssScore: 8.6,
      hasCvssVector: true,
      epssProbability: 0.82,
      isKnownExploited: false,
      hasWeaknessClassification: true,
      sourceCount: 3,
      referenceCount: 6,
      hasDescription: true,
      hasTimeline: true,
    },
  ),

  createScenario(
    {
      id: "moderate-vulnerability",
      name: "Moderate vulnerability",
      description:
        "Moderate technical severity with no current exploitation signal.",
    },
    {
      cvssScore: 5.4,
      hasCvssVector: true,
      epssProbability: 0.02,
      isKnownExploited: false,
      hasWeaknessClassification: true,
      sourceCount: 2,
      referenceCount: 4,
      hasDescription: true,
      hasTimeline: true,
    },
  ),

  createScenario(
    {
      id: "incomplete-intelligence",
      name: "Incomplete intelligence",
      description:
        "A poorly documented vulnerability with several missing intelligence signals.",
    },
    {
      sourceCount: 1,
      referenceCount: 0,
      hasDescription: false,
      hasTimeline: false,
    },
  ),
];

const assessments = scenarios.map(({ source, context }) => {
  const brief = buildExecutiveBrief(context);

  return {
    source,
    signals: context.signals,
    ...brief,
  };
});

function createScenario(
  source: ScenarioSource,
  signals: IntelligenceContext<ScenarioSource>["signals"],
): Scenario {
  return {
    source,
    context: {
      source,
      signals,
    },
  };
}

function formatEpss(value: number | undefined): string {
  if (typeof value !== "number") {
    return "Unavailable";
  }

  return `${(value * 100).toFixed(2)}%`;
}

function formatBoolean(value: boolean | undefined): string {
  if (value === true) {
    return "Yes";
  }

  if (value === false) {
    return "No";
  }

  return "Unavailable";
}

function formatConfidenceLevel(level: string): string {
  return level.replaceAll("_", " ");
}

function getUrgencyClass(urgency: string): string {
  return `urgency urgency--${urgency.toLowerCase()}`;
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>MM Intelligence Engine Playground</title>

    <meta
      name="description"
      content="Development playground for the MM Intelligence Engine."
    />
  </head>

  <body>
    <main class="playground">
      <header class="playground__header">
        <p class="eyebrow">
          MM Labs · Internal development tool
        </p>

        <h1>
          Intelligence Engine
          <span>Playground</span>
        </h1>

        <p class="intro">
          This page validates how the engine transforms normalized
          vulnerability signals into operational decisions and
          explainable confidence assessments.
        </p>

        <div class="principles">
          <span>Decision ≠ severity</span>
          <span>Confidence ≠ urgency</span>
          <span>Confirmed exploitation overrides probability</span>
        </div>
      </header>

      <section class="scenario-grid">
        {
          assessments.map(
          ({
            source,
            signals,
            executiveSummary,
            decision,
            confidence,
            businessImpact,
            actions,
            reasoning,
            analystNotes,
          }) => (
              <article class="scenario-card">
                <header class="scenario-card__header">
                  <div>
                    <p class="scenario-id">
                      {source.id}
                    </p>

                    <h2>{source.name}</h2>
                  </div>

                  <span
                    class={getUrgencyClass(decision.urgency)}
                  >
                    {decision.urgency}
                  </span>
                </header>

                <p class="scenario-description">
                  {source.description}
                </p>

                <section class="executive-summary">
                  <p class="section-label">Executive brief</p>

                  <p>{executiveSummary}</p>
                </section>

                <section class="signal-panel">
                  <p class="section-label">
                    Normalized signals
                  </p>

                  <dl class="signal-list">
                    <div>
                      <dt>CVSS</dt>
                      <dd>
                        {signals.cvssScore ?? "Unavailable"}
                      </dd>
                    </div>

                    <div>
                      <dt>EPSS</dt>
                      <dd>
                        {formatEpss(
                          signals.epssProbability,
                        )}
                      </dd>
                    </div>

                    <div>
                      <dt>CISA KEV</dt>
                      <dd>
                        {formatBoolean(
                          signals.isKnownExploited,
                        )}
                      </dd>
                    </div>

                    <div>
                      <dt>Sources</dt>
                      <dd>
                        {signals.sourceCount ?? 0}
                      </dd>
                    </div>
                  </dl>
                </section>

                <section class="result-panel">
                  <div class="result-heading">
                    <div>
                      <p class="section-label">
                        Executive decision
                      </p>

                      <h3>{decision.title}</h3>
                    </div>

                    <strong class="large-score">
                      {decision.score}
                      <span>/100</span>
                    </strong>
                  </div>

                  <div
                    class="progress"
                    role="progressbar"
                    aria-label="Decision score"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-valuenow={decision.score}
                  >
                    <span
                      style={`width: ${decision.score}%`}
                    />
                  </div>

                  <p class="result-description">
                    {decision.summary}
                  </p>
                </section>

                <section class="result-panel">
                  <div class="result-heading">
                    <div>
                      <p class="section-label">
                        Assessment confidence
                      </p>

                      <h3>
                        {formatConfidenceLevel(
                          confidence.level,
                        )}
                      </h3>
                    </div>

                    <strong class="large-score">
                      {confidence.score}
                      <span>%</span>
                    </strong>
                  </div>

                  <div
                    class="progress"
                    role="progressbar"
                    aria-label="Assessment confidence"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-valuenow={confidence.score}
                  >
                    <span
                      style={`width: ${confidence.score}%`}
                    />
                  </div>

                  <p class="result-description">
                    {confidence.summary}
                  </p>
                </section>

<section class="result-panel business-impact-panel">
  <div class="result-heading">
    <div>
      <p class="section-label">
        Business impact
      </p>

      <h3>{businessImpact.title}</h3>
    </div>

    <span
      class={getUrgencyClass(
        businessImpact.level,
      )}
    >
      {businessImpact.level}
    </span>
  </div>

  <p class="result-description">
    {businessImpact.summary}
  </p>

  <div class="executive-message">
    <span>Executive message</span>

    <strong>
      {businessImpact.executiveMessage}
    </strong>
  </div>

  <div class="consequences">
    <p class="consequences__title">
      Potential consequences
    </p>

    <ul>
      {
        businessImpact.potentialConsequences.map(
          (consequence) => (
            <li>{consequence}</li>
          ),
        )
      }
    </ul>
  </div>
</section>

                <section class="result-panel actions-panel">
                  <div class="result-heading">
                    <div>
                      <p class="section-label">Immediate actions</p>
                      <h3>Recommended response</h3>
                    </div>
                  </div>

                  <ul class="action-list">
                    {
                      actions.map((action) => (
                        <li class="action-item">
                          <div>
                            <strong>{action.title}</strong>
                            <p>{action.description}</p>
                          </div>

                          <span
                            class={`priority priority--${action.priority.toLowerCase()}`}
                          >
                            {action.priority}
                          </span>
                        </li>
                      ))
                    }
                  </ul>
                </section>

                <section class="analyst-notes">
                  <p class="section-label">Analyst considerations</p>
                  <p>{analystNotes}</p>
                </section>

                <details class="reasoning-details">
                  <summary>
                    Inspect engine reasoning
                  </summary>

                  <div class="reasoning-list">
                    {
                      reasoning.map((item) => (
                        <article class="reasoning-item">
                          <div class="reasoning-item__header">
                            <div>
                              <h4>{item.title}</h4>

                              {
                                item.source && (
                                  <span class="reasoning-source">
                                    {item.source}
                                  </span>
                                )
                              }
                            </div>

                            <strong
                              class:list={[
                                "reasoning-contribution",
                                {
                                  "reasoning-contribution--zero":
                                    item.scoreContribution === 0,
                                },
                              ]}
                            >
                              +{item.scoreContribution}
                            </strong>
                          </div>

                          <p>{item.description}</p>

                          {
                            typeof item.confidence ===
                              "number" && (
                              <div class="reasoning-confidence">
                                <span>
                                  Signal confidence
                                </span>

                                <strong>
                                  {item.confidence}%
                                </strong>
                              </div>
                            )
                          }
                        </article>
                      ))
                    }

                    <footer class="reasoning-total">
                      <span>
                        Total decision score
                      </span>

                      <strong>
                        {decision.score}/100
                      </strong>
                    </footer>
                  </div>
                </details>
              </article>
            ),
          )
        }
      </section>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    min-width: 320px;
    background: #07101d;
    color-scheme: dark;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  :global(body) {
    margin: 0;
    color: #e8eef8;
    background:
      radial-gradient(
        circle at top left,
        rgb(32 95 150 / 18%),
        transparent 32rem
      ),
      #07101d;
  }

  .playground {
    width: min(1500px, calc(100% - 32px));
    margin: 0 auto;
    padding: 64px 0 96px;
  }

  .playground__header {
    max-width: 900px;
    margin-bottom: 48px;
  }

  .eyebrow,
  .section-label,
  .scenario-id {
    margin: 0;
    color: #5fb5ff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    margin: 10px 0 16px;
    font-size: clamp(2.4rem, 6vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.055em;
  }

  h1 span {
    display: block;
  }

  .intro {
    max-width: 760px;
    margin: 0;
    color: #a9b6c8;
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .principles {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .principles span {
    padding: 8px 12px;
    border: 1px solid rgb(113 154 195 / 24%);
    border-radius: 999px;
    color: #c6d4e4;
    background: rgb(16 34 54 / 72%);
    font-size: 0.82rem;
  }

  .scenario-grid {
    display: grid;
    grid-template-columns:
      repeat(
        auto-fit,
        minmax(min(100%, 420px), 1fr)
      );
    align-items: start;
    gap: 22px;
  }

  .scenario-card {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 24px;
    border: 1px solid rgb(117 151 188 / 18%);
    border-radius: 22px;
    background:
      linear-gradient(
        145deg,
        rgb(17 34 53 / 96%),
        rgb(9 21 36 / 96%)
      );
    box-shadow: 0 20px 60px rgb(0 0 0 / 20%);
  }

  .scenario-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .scenario-card h2 {
    margin: 6px 0 0;
    font-size: 1.35rem;
    line-height: 1.25;
  }

  .scenario-description {
    min-height: 48px;
    margin: 0;
    color: #98a9bd;
    line-height: 1.55;
  }

  .urgency {
    flex: 0 0 auto;
    padding: 7px 10px;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .urgency--critical {
    color: #ff8b8b;
    background: rgb(255 70 70 / 8%);
  }

  .urgency--high {
    color: #ffc170;
    background: rgb(255 155 48 / 8%);
  }

  .urgency--medium {
    color: #ffe27a;
    background: rgb(255 210 70 / 8%);
  }

  .urgency--low {
    color: #73dfac;
    background: rgb(53 201 135 / 8%);
  }

  .signal-panel,
  .result-panel {
    padding: 18px;
    border: 1px solid rgb(116 150 186 / 15%);
    border-radius: 16px;
    background: rgb(4 14 26 / 44%);
  }

  .signal-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin: 14px 0 0;
    overflow: hidden;
    border: 1px solid rgb(116 150 186 / 12%);
    border-radius: 11px;
    background: rgb(116 150 186 / 12%);
  }

  .signal-list div {
    min-width: 0;
    padding: 12px 10px;
    background: #0c1929;
  }

  .signal-list dt {
    color: #75879d;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .signal-list dd {
    margin: 5px 0 0;
    overflow-wrap: anywhere;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .result-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .result-panel h3 {
    margin: 7px 0 0;
    font-size: 1.24rem;
  }

  .large-score {
    flex: 0 0 auto;
    color: #eff6ff;
    font-size: 1.65rem;
    line-height: 1;
  }

  .large-score span {
    color: #7f91a7;
    font-size: 0.74rem;
  }

  .progress {
    height: 7px;
    margin-top: 16px;
    overflow: hidden;
    border-radius: 999px;
    background: #14263a;
  }

  .progress span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background:
      linear-gradient(
        90deg,
        #2d8ae7,
        #73c5ff
      );
  }

  .result-description {
    margin: 16px 0 0;
    color: #a4b2c3;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .reasoning-details {
    margin-top: auto;
    border-top: 1px solid rgb(116 150 186 / 15%);
    padding-top: 17px;
  }

  summary {
    cursor: pointer;
    color: #7bbcff;
    font-size: 0.83rem;
    font-weight: 700;
  }

  .reasoning-list {
    display: grid;
    gap: 10px;
    margin-top: 15px;
  }

  .reasoning-item {
    padding: 14px;
    border: 1px solid rgb(116 150 186 / 14%);
    border-radius: 12px;
    background: rgb(5 14 25 / 70%);
  }

  .reasoning-item__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .reasoning-item h4 {
    margin: 0;
    font-size: 0.88rem;
  }

  .reasoning-source {
    display: inline-block;
    margin-top: 5px;
    color: #70859d;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .reasoning-contribution {
    flex: 0 0 auto;
    color: #70d7a7;
    font-size: 1rem;
  }

  .reasoning-contribution--zero {
    color: #77899e;
  }

  .reasoning-item p {
    margin: 10px 0 0;
    color: #9cadc1;
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .reasoning-confidence {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 11px;
    padding-top: 10px;
    border-top: 1px solid rgb(116 150 186 / 10%);
    color: #71849a;
    font-size: 0.7rem;
  }

  .reasoning-confidence strong {
    color: #adbed1;
  }

  .reasoning-total {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 14px;
    border: 1px solid rgb(63 155 238 / 24%);
    border-radius: 12px;
    color: #abd3f6;
    background: rgb(29 103 170 / 10%);
    font-size: 0.82rem;
  }

  .reasoning-total strong {
    color: #eef8ff;
    font-size: 1rem;
  }

  @media (max-width: 620px) {
    .playground {
      width: min(100% - 20px, 1500px);
      padding-top: 38px;
    }

    .scenario-card {
      padding: 18px;
    }

    .signal-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .business-impact-panel {
  background:
    linear-gradient(
      145deg,
      rgb(19 39 57 / 74%),
      rgb(5 17 30 / 70%)
    );
}

.executive-message {
  display: grid;
  gap: 6px;
  margin-top: 16px;
  padding: 13px 14px;
  border: 1px solid rgb(95 181 255 / 18%);
  border-radius: 11px;
  background: rgb(33 113 183 / 8%);
}

.executive-message span,
.consequences__title {
  color: #70859d;
  font-size: 0.66rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.executive-message strong {
  color: #cfe8ff;
  font-size: 0.86rem;
  line-height: 1.45;
}

.consequences {
  margin-top: 16px;
}

.consequences__title {
  margin: 0 0 9px;
}

.consequences ul {
  display: grid;
  gap: 7px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.consequences li {
  position: relative;
  padding-left: 15px;
  color: #a4b2c3;
  font-size: 0.82rem;
  line-height: 1.45;
}

.consequences li::before {
  position: absolute;
  top: 0.5em;
  left: 0;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #5fb5ff;
  content: "";
}
.executive-summary {
  padding: 18px;
  border: 1px solid rgb(95 181 255 / 18%);
  border-radius: 16px;
  background:
    linear-gradient(
      145deg,
      rgb(44 119 197 / 18%),
      rgb(18 39 65 / 35%)
    );
}

.executive-summary p:last-child {
  margin: 10px 0 0;
  color: #d7e6f8;
  font-size: 0.95rem;
  line-height: 1.6;
}

.action-list {
  display: grid;
  gap: 12px;
  margin: 18px 0 0;
  padding: 0;
  list-style: none;
}

.action-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  padding: 14px;
  border: 1px solid rgb(255 255 255 / 6%);
  border-radius: 12px;
  background: #0c1929;
}

.action-item strong {
  display: block;
  margin-bottom: 6px;
}

.action-item p {
  margin: 0;
  color: #9cadc1;
  font-size: 0.85rem;
  line-height: 1.45;
}

.priority {
  flex: 0 0 auto;
  padding: 5px 10px;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
}

.priority--critical {
  color: #ffb2b2;
  background: #5d1717;
}

.priority--high {
  color: #ffd391;
  background: #5d4217;
}

.priority--medium {
  color: #fff0a8;
  background: #5d5717;
}

.priority--low {
  color: #b8ffd7;
  background: #1b4b33;
}

.analyst-notes {
  padding: 16px 18px;
  border: 1px dashed rgb(116 150 186 / 20%);
  border-radius: 14px;
  background: rgb(5 14 25 / 44%);
}

.analyst-notes p:last-child {
  margin: 9px 0 0;
  color: #91a3b8;
  font-size: 0.82rem;
  line-height: 1.5;
}

</style>