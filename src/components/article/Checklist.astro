---
const {
	title = 'Checklist opérationnelle',
	items = [],
} = Astro.props;
---

<section class="checklist">
	<h3>{title}</h3>

	<ul>
		{items.map((item) => (
			<li>{item}</li>
		))}
	</ul>
</section>

<style>
	.checklist {
		margin: 2.5rem 0;
		padding: 2rem;
		border-radius: 24px;
		background: #f8fafc;
		border: 1px solid #e5e7eb;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.checklist h3 {
		margin: 0 0 1.25rem;
		font-size: 1.5rem;
		color: #0f172a;
	}

	.checklist ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: .9rem;
	}

	.checklist li {
		position: relative;
		padding-left: 2rem;
		color: #334155;
		line-height: 1.7;
	}

	.checklist li::before {
		content: "✓";
		position: absolute;
		left: 0;
		top: 0;
		color: #2563eb;
		font-weight: 900;
	}
</style>