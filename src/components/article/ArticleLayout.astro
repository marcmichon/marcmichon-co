---
const { toc = [] } = Astro.props;
---

<div class="article-layout">
	{toc.length > 0 && (
		<aside class="article-toc">
			<p>Sommaire</p>

			<nav>
				{toc.map((item) => (
					<a href={`#${item.id}`}>{item.label}</a>
				))}
			</nav>
		</aside>
	)}

	<article class="article-content">
		<slot />
	</article>
</div>

<style>
	.article-layout {
		display: grid;
		grid-template-columns: 280px 1fr;
		gap: 3rem;
		align-items: start;
	}

	.article-toc {
		position: sticky;
		top: 2rem;
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 22px;
		padding: 1.5rem;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.article-toc p {
		margin: 0 0 1rem;
		font-weight: 900;
		color: #0f172a;
	}

	.article-toc nav {
		display: grid;
		gap: .75rem;
	}

	.article-toc a {
		color: #475569;
		text-decoration: none;
		font-weight: 600;
		line-height: 1.4;
	}

	.article-toc a:hover {
		color: #2563eb;
	}

	.article-content {
		background: white;
		border: 1px solid #e5e7eb;
		border-radius: 28px;
		padding: 3rem;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.article-content :global(h2) {
		font-size: 2.3rem;
		line-height: 1.15;
		letter-spacing: -0.04em;
		margin: 3rem 0 1.25rem;
		color: #0f172a;
	}

	.article-content :global(h2:first-child) {
		margin-top: 0;
	}

	.article-content :global(h3) {
		font-size: 1.5rem;
		margin: 2rem 0 1rem;
		color: #0f172a;
	}

	.article-content :global(p),
	.article-content :global(li) {
		font-size: 1.1rem;
		line-height: 1.85;
		color: #334155;
	}

	.article-content :global(ul),
	.article-content :global(ol) {
		padding-left: 1.5rem;
	}

	.article-content :global(strong) {
		color: #0f172a;
	}

	@media (max-width: 1000px) {
		.article-layout {
			grid-template-columns: 1fr;
		}

		.article-toc {
			position: static;
		}
	}

	@media (max-width: 640px) {
		.article-content {
			padding: 2rem;
		}
	}
</style>