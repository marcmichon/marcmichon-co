---
const {
	tag = 'NOTE DE TERRAIN',
	title,
	subtitle,
	image,
	readTime = '15 min',
	level = 'Intermédiaire',
	updated = 'Mis à jour récemment',
	technologies = [],
} = Astro.props;
---

<section class="article-hero">
	<div class="article-hero-text">
		<p class="article-tag">{tag}</p>

		<h1>{title}</h1>

		<p class="article-subtitle">{subtitle}</p>

		<div class="article-meta">
			<span>{readTime}</span>
			<span>{level}</span>
			<span>{updated}</span>
		</div>

		{technologies.length > 0 && (
			<div class="article-tech">
				{technologies.map((tech) => (
					<span>{tech}</span>
				))}
			</div>
		)}
	</div>

	{image && (
		<div class="article-hero-image">
			<img src={image} alt="" />
		</div>
	)}
</section>

<style>
	.article-hero {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 4rem;
		align-items: center;

		padding: 5rem;
		border-radius: 32px;
		margin-bottom: 3rem;

		color: white;

		background:
			linear-gradient(rgba(2,8,23,.82), rgba(2,8,23,.82)),
			url('/Images/fondsite.png');

		background-size: cover;
		background-position: center;

		box-shadow: 0 25px 60px rgba(2,8,23,.2);
	}

	.article-tag {
		color: #60a5fa;
		font-weight: 900;
		font-size: .85rem;
		letter-spacing: .12em;
		text-transform: uppercase;
		margin: 0 0 1rem;
	}

	h1 {
		font-size: 4.5rem;
		line-height: .95;
		letter-spacing: -0.05em;
		margin: 0 0 2rem;
		color: white;
	}

	.article-subtitle {
		max-width: 820px;
		color: #dbeafe;
		font-size: 1.25rem;
		line-height: 1.8;
		margin: 0;
	}

	.article-meta {
		display: flex;
		flex-wrap: wrap;
		gap: .75rem;
		margin-top: 2rem;
	}

	.article-meta span,
	.article-tech span {
		padding: .7rem 1rem;
		border-radius: 999px;
		background: rgba(255,255,255,.08);
		border: 1px solid rgba(255,255,255,.18);
		color: #dbeafe;
		font-weight: 800;
		font-size: .9rem;
	}

	.article-tech {
		display: flex;
		flex-wrap: wrap;
		gap: .75rem;
		margin-top: 1rem;
	}

	.article-tech span {
		background: rgba(37,99,235,.25);
		border-color: rgba(96,165,250,.35);
		color: #93c5fd;
	}

	.article-hero-image img {
		width: 100%;
		border-radius: 28px;
		display: block;
		box-shadow: 0 30px 70px rgba(0,0,0,.45);
	}

	@media (max-width: 1000px) {
		.article-hero {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.article-hero {
			padding: 3rem 2rem;
		}

		h1 {
			font-size: 3rem;
		}
	}
</style>