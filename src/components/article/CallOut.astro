---
const {
	type = 'info',
	title = 'Note',
} = Astro.props;

const labels = {
	field: 'NOTE TERRAIN',
	best: 'BONNE PRATIQUE',
	warning: 'POINT D’ATTENTION',
	error: 'ERREUR FRÉQUENTE',
	info: 'NOTE',
};

const label = labels[type] || title;
---

<div class={`callout ${type}`}>
	<p class="callout-label">{label}</p>
	<div class="callout-content">
		<slot />
	</div>
</div>

<style>
	.callout {
		border-radius: 22px;
		padding: 1.75rem;
		margin: 2rem 0;
		border: 1px solid #e5e7eb;
		background: white;
		box-shadow: 0 10px 30px rgba(15,23,42,.04);
	}

	.callout-label {
		margin: 0 0 1rem;
		font-size: .78rem;
		font-weight: 900;
		letter-spacing: .12em;
		text-transform: uppercase;
	}

	.callout-content :global(p) {
		margin: 0;
		line-height: 1.8;
		color: #334155;
	}

	.callout.field {
		background: #eff6ff;
		border-color: #bfdbfe;
	}

	.callout.field .callout-label {
		color: #2563eb;
	}

	.callout.best {
		background: #ecfdf5;
		border-color: #bbf7d0;
	}

	.callout.best .callout-label {
		color: #059669;
	}

	.callout.warning {
		background: #fffbeb;
		border-color: #fde68a;
	}

	.callout.warning .callout-label {
		color: #d97706;
	}

	.callout.error {
		background: #fef2f2;
		border-color: #fecaca;
	}

	.callout.error .callout-label {
		color: #dc2626;
	}

	.callout.info {
		background: #f8fafc;
		border-color: #e5e7eb;
	}

	.callout.info .callout-label {
		color: #2563eb;
	}
</style>