---
import { SITE_TITLE } from '../consts';
---

<header class="mm-header">
	<nav class="mm-nav" aria-label="Navigation principale">
		<a class="mm-brand" href="/">{SITE_TITLE}</a>

		<button class="mm-menu-button" type="button" aria-expanded="false" aria-controls="mm-menu">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<div id="mm-menu" class="mm-menu">
			<a href="/">Accueil</a>
			<a href="/notes-de-terrain">Notes de terrain</a>
			<a href="/expertise">Expertise</a>
			<a href="/certifications">Certifications</a>
			<a href="/about">À propos</a>
			<a href="/contact">Contact</a>
			<a class="mm-linkedin" href="https://www.linkedin.com/in/michonmarc" target="_blank" rel="noopener noreferrer">
				Mon profil LinkedIn →
			</a>
		</div>
	</nav>
</header>

<script is:inline>
	const button = document.querySelector('.mm-menu-button');
	const menu = document.querySelector('#mm-menu');

	if (button && menu) {
		button.addEventListener('click', () => {
			const isOpen = button.getAttribute('aria-expanded') === 'true';
			button.setAttribute('aria-expanded', String(!isOpen));
			menu.classList.toggle('is-open');
		});
	}
</script>

<style is:global>
	.mm-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(18px);
		border-bottom: 1px solid #e5e7eb;
	}

	.mm-nav {
		width: min(1320px, calc(100% - 4rem));
		min-height: 82px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	.mm-brand {
		color: #0f172a;
		font-size: 1.75rem;
		font-weight: 900;
		line-height: 1;
		letter-spacing: -0.05em;
		text-decoration: none;
		white-space: nowrap;
	}

	.mm-menu {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	.mm-menu a {
		color: #0f172a;
		font-size: 0.95rem;
		font-weight: 800;
		text-decoration: none;
		padding: 0.75rem 0.85rem;
		border-radius: 999px;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.mm-menu a:hover,
	.mm-menu a[aria-current='page'] {
		color: #2563eb;
		background: #eff6ff;
	}

	.mm-linkedin {
		color: #2563eb !important;
		white-space: nowrap;
	}

	.mm-menu-button {
		display: none;
	}

	@media (max-width: 980px) {
		.mm-nav {
			width: min(100% - 2rem, 1320px);
			min-height: 74px;
			position: relative;
		}

		.mm-brand {
			font-size: 1.45rem;
		}

		.mm-menu-button {
			width: 46px;
			height: 46px;
			border: 1px solid #e5e7eb;
			border-radius: 14px;
			background: #f8fafc;
			display: grid;
			place-content: center;
			gap: 5px;
			cursor: pointer;
		}

		.mm-menu-button span {
			display: block;
			width: 20px;
			height: 2px;
			border-radius: 999px;
			background: #0f172a;
			transition: transform 0.2s ease, opacity 0.2s ease;
		}

		.mm-menu-button[aria-expanded='true'] span:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}

		.mm-menu-button[aria-expanded='true'] span:nth-child(2) {
			opacity: 0;
		}

		.mm-menu-button[aria-expanded='true'] span:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}

		.mm-menu {
			position: absolute;
			top: calc(100% + 0.75rem);
			left: 0;
			right: 0;
			display: none;
			grid-template-columns: 1fr;
			gap: 0.35rem;
			padding: 1rem;
			border-radius: 22px;
			background: white;
			border: 1px solid #e5e7eb;
			box-shadow: 0 24px 60px rgba(15, 23, 42, 0.16);
		}

		.mm-menu.is-open {
			display: grid;
		}

		.mm-menu a {
			display: block;
			padding: 0.95rem 1rem;
			border-radius: 14px;
			font-size: 1rem;
		}

		.mm-linkedin {
			margin-top: 0.5rem;
			text-align: center;
			background: #eff6ff;
		}
	}
</style>