<section class="risk-tool">
	<div class="risk-panel">
		<div class="field">
			<label for="scenario">Scénario</label>
			<input id="scenario" type="text" value="Serveur exposé avec vulnérabilité critique" />
		</div>

		<div class="field">
			<label for="asset">Asset concerné</label>
			<input id="asset" type="text" value="Application web publique" />
		</div>

		<div class="sliders">
			<div class="field">
				<label for="likelihood">Probabilité <span id="likelihood-value">3</span>/5</label>
				<input id="likelihood" type="range" min="1" max="5" value="3" />
			</div>

			<div class="field">
				<label for="impact">Impact <span id="impact-value">4</span>/5</label>
				<input id="impact" type="range" min="1" max="5" value="4" />
			</div>
		</div>

		<div class="field">
			<label for="controls">Contrôles existants</label>
			<textarea id="controls">EDR, WAF, supervision SOC, sauvegardes</textarea>
		</div>
	</div>

	<div class="result-card" id="result-card">
		<p class="result-label">Niveau de risque</p>
		<h2 id="risk-level">Élevé</h2>

		<div class="score">
			<span>Score</span>
			<strong id="risk-score">12</strong>
		</div>

		<p id="risk-summary">
			Le scénario présente un risque élevé. La priorité doit porter sur la réduction de la probabilité ou la limitation de l’impact.
		</p>

		<button id="copy-result" type="button">Copier le résultat</button>
		<button id="clear-draft" class="secondary-button" type="button">
	Effacer le brouillon
</button>
	</div>
</section>

<script is:inline>
	const likelihood = document.querySelector('#likelihood');
	const impact = document.querySelector('#impact');
	const likelihoodValue = document.querySelector('#likelihood-value');
	const impactValue = document.querySelector('#impact-value');
	const riskScore = document.querySelector('#risk-score');
	const riskLevel = document.querySelector('#risk-level');
	const riskSummary = document.querySelector('#risk-summary');
	const resultCard = document.querySelector('#result-card');
	const scenario = document.querySelector('#scenario');
	const asset = document.querySelector('#asset');
	const controls = document.querySelector('#controls');
	const copyButton = document.querySelector('#copy-result');
	const clearDraftButton = document.querySelector('#clear-draft');

	const STORAGE_KEY = 'mm-risk-score-draft-v1';

	function getRisk(score) {
		if (score <= 4) {
			return {
				level: 'Faible',
				className: 'low',
				text:
					'Le scénario présente un risque faible. Le risque peut être suivi, mais ne nécessite pas forcément une action prioritaire.'
			};
		}

		if (score <= 9) {
			return {
				level: 'Modéré',
				className: 'medium',
				text:
					'Le scénario présente un risque modéré. Il doit être suivi et traité selon les priorités opérationnelles.'
			};
		}

		if (score <= 14) {
			return {
				level: 'Élevé',
				className: 'high',
				text:
					'Le scénario présente un risque élevé. La priorité doit porter sur la réduction de la probabilité ou la limitation de l’impact.'
			};
		}

		return {
			level: 'Critique',
			className: 'critical',
			text:
				'Le scénario présente un risque critique. Une action rapide est recommandée afin de réduire l’exposition ou l’impact potentiel.'
		};
	}

	function updateRisk() {
		const l = Number(likelihood.value);
		const i = Number(impact.value);
		const score = l * i;
		const risk = getRisk(score);

		likelihoodValue.textContent = String(l);
		impactValue.textContent = String(i);
		riskScore.textContent = String(score);
		riskLevel.textContent = risk.level;
		riskSummary.textContent = risk.text;

		resultCard.className = `result-card ${risk.className}`;
	}

	function getFormState() {
		return {
			scenario: scenario.value,
			asset: asset.value,
			likelihood: likelihood.value,
			impact: impact.value,
			controls: controls.value
		};
	}

	function saveFormState() {
		const state = getFormState();

		localStorage.setItem(
			STORAGE_KEY,
			JSON.stringify(state)
		);
	}

	function loadFormState() {
		const savedState = localStorage.getItem(STORAGE_KEY);

		if (!savedState) {
			return;
		}

		try {
			const state = JSON.parse(savedState);

			scenario.value = state.scenario ?? scenario.value;
			asset.value = state.asset ?? asset.value;
			likelihood.value = state.likelihood ?? likelihood.value;
			impact.value = state.impact ?? impact.value;
			controls.value = state.controls ?? controls.value;

			updateRisk();
		} catch (error) {
			console.error(
				'Impossible de restaurer le brouillon MM Risk Score.',
				error
			);

			localStorage.removeItem(STORAGE_KEY);
		}
	}

	function clearDraft() {
		localStorage.removeItem(STORAGE_KEY);

		scenario.value =
			'Serveur exposé avec vulnérabilité critique';

		asset.value =
			'Application web publique';

		likelihood.value = '3';
		impact.value = '4';

		controls.value =
			'EDR, WAF, supervision SOC, sauvegardes';

		updateRisk();

		clearDraftButton.textContent = 'Brouillon effacé';

		setTimeout(() => {
			clearDraftButton.textContent = 'Effacer le brouillon';
		}, 1800);
	}

	async function copyResult() {
		const text = `Scénario : ${scenario.value}
Asset : ${asset.value}
Probabilité : ${likelihood.value}/5
Impact : ${impact.value}/5
Score : ${riskScore.textContent}
Niveau : ${riskLevel.textContent}
Contrôles existants : ${controls.value}
Analyse : ${riskSummary.textContent}`;

		try {
			await navigator.clipboard.writeText(text);

			copyButton.textContent = 'Résultat copié';

			setTimeout(() => {
				copyButton.textContent = 'Copier le résultat';
			}, 1800);
		} catch (error) {
			console.error(
				'Impossible de copier le résultat.',
				error
			);

			copyButton.textContent = 'Copie impossible';

			setTimeout(() => {
				copyButton.textContent = 'Copier le résultat';
			}, 1800);
		}
	}

	likelihood.addEventListener('input', updateRisk);
	impact.addEventListener('input', updateRisk);

	scenario.addEventListener('input', saveFormState);
	asset.addEventListener('input', saveFormState);
	likelihood.addEventListener('input', saveFormState);
	impact.addEventListener('input', saveFormState);
	controls.addEventListener('input', saveFormState);

	copyButton.addEventListener('click', copyResult);
	clearDraftButton.addEventListener('click', clearDraft);

	loadFormState();
	updateRisk();
</script>

