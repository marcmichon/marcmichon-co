		background:
			radial-gradient(circle at 80% 0%, rgba(96,165,250,.22), transparent 35%),
			linear-gradient(135deg, #020817 0%, #06142d 55%, #031b4d 100%);
		border-color: rgba(96,165,250,.25);
	}

	.result-label {
		margin: 0 0 .5rem;
		color: #93c5fd;
		font-size: .8rem;
