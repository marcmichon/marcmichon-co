		letter-spacing: .12em;
		text-transform: uppercase;
	}

	.result-card h2 {
		color: white;
		font-size: 3rem;
		margin: 0 0 1.5rem;
	}

	.score {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem;
		border-radius: 18px;
		background: rgba(255,255,255,.08);
		margin-bottom: 1.5rem;
	}

	.score span {
